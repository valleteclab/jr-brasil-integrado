model EntradaFiscal {
  id              String              @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa             @relation(fields: [empresaId], references: [id])
  fornecedorId    String?
  fornecedor      Fornecedor?         @relation(fields: [fornecedorId], references: [id])
  xmlImportacaoId String?
  xmlImportacao   XmlImportacao?      @relation(fields: [xmlImportacaoId], references: [id])
  chaveAcesso     String?
  numero          String?
  serie           String?
  modelo          String?
  cfopPrincipal   String?
  status          StatusEntradaFiscal @default(AGUARDANDO_CONFERENCIA)
  emitidaEm       DateTime?
  recebidaEm      DateTime?
  totalProdutos   Decimal             @default(0) @db.Decimal(14, 2)
  totalNota       Decimal             @default(0) @db.Decimal(14, 2)
  valorFrete      Decimal             @default(0) @db.Decimal(14, 2)
  valorSeguro     Decimal             @default(0) @db.Decimal(14, 2)
  valorDesconto   Decimal             @default(0) @db.Decimal(14, 2)
  outrasDespesas  Decimal             @default(0) @db.Decimal(14, 2)
  observacoes     String?
  // Totais fiscais da NF-e — essenciais para SPED EFD e conciliação contábil
  valorBCICMS     Decimal?            @db.Decimal(14, 2)
  valorICMS       Decimal?            @db.Decimal(14, 2)
  valorBCICMSST   Decimal?            @db.Decimal(14, 2)
  valorICMSST     Decimal?            @db.Decimal(14, 2)
  valorIPI        Decimal?            @db.Decimal(14, 2)
  valorPIS        Decimal?            @db.Decimal(14, 2)
  valorCOFINS     Decimal?            @db.Decimal(14, 2)
  valorFCP        Decimal?            @db.Decimal(14, 2)
  valorFCPST      Decimal?            @db.Decimal(14, 2)
  valorTributos   Decimal?            @db.Decimal(14, 2)
  // Modal frete: 0-CIF, 1-FOB, 2-Terceiros, 3-Próprio Remetente, 4-Próprio Destinatário, 9-Sem frete
  modalidadeFrete Int?
  itens           EntradaFiscalItem[]
  parcelas        EntradaFiscalParcela[]
  contasPagar     ContaPagar[]
  criadoEm        DateTime            @default(now())
  atualizadoEm    DateTime            @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, fornecedorId])
}

model EntradaFiscalParcela {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  entradaFiscalId String
  entradaFiscal   EntradaFiscal @relation(fields: [entradaFiscalId], references: [id])
  contaPagar      ContaPagar?
  numero          String
  vencimento      DateTime
  valor           Decimal        @db.Decimal(14, 2)
  formaPagamento  String?
  origem          String         @default("XML")
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([tenantId, empresaId, entradaFiscalId, numero])
  @@index([tenantId, empresaId, entradaFiscalId])
  @@index([tenantId, empresaId, vencimento])
}

model EntradaFiscalItem {
  id                              String                     @id @default(cuid())
  tenantId                        String
  empresaId                       String
  entradaFiscalId                 String
  produtoId                       String?
  entradaFiscal                   EntradaFiscal              @relation(fields: [entradaFiscalId], references: [id])
  produto                         Produto?                   @relation(fields: [produtoId], references: [id])
  itemNumero                      Int
  codigoFornecedor                String
  descricaoFornecedor             String
  gtin                            String?
  ncm                             String?
  cest                            String?
  cfop                            String?
  unidade                         String
  quantidade                      Decimal                    @db.Decimal(14, 4)
  valorUnitario                   Decimal                    @db.Decimal(14, 4)
  valorTotal                      Decimal                    @db.Decimal(14, 2)
  valorDesconto                   Decimal                    @default(0) @db.Decimal(14, 2)
  precoVendaDefinido              Decimal?                   @db.Decimal(14, 2)
  precoMinimoDefinido             Decimal?                   @db.Decimal(14, 2)
  marcaDefinida                   String?
  produtoVinculadoAutomaticamente Boolean                    @default(false)
  confiancaVinculo                Decimal?                   @db.Decimal(8, 4)
  revisarVinculo                  Boolean                    @default(true)
  impostos                        EntradaFiscalItemImposto[]
  criadoEm                        DateTime                   @default(now())
  atualizadoEm                    DateTime                   @updatedAt

  @@unique([tenantId, empresaId, entradaFiscalId, itemNumero])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, codigoFornecedor])
  @@index([tenantId, empresaId, ncm])
}

model EntradaFiscalItemImposto {
  id                  String            @id @default(cuid())
  tenantId            String
  empresaId           String
  entradaFiscalItemId String
  entradaFiscalItem   EntradaFiscalItem @relation(fields: [entradaFiscalItemId], references: [id])
  tributo             TipoTributo
  cst                 String?
  csosn               String?
  cClassTrib          String?
  baseCalculo         Decimal?          @db.Decimal(14, 2)
  aliquota            Decimal?          @db.Decimal(8, 4)
  valor               Decimal?          @db.Decimal(14, 2)
  recuperavel         Boolean           @default(false)
  // ICMS-ST — preenchido quando CST ICMS é 10, 30, 70 ou 90
  baseST              Decimal?          @db.Decimal(14, 2)
  aliquotaST          Decimal?          @db.Decimal(8, 4)
  valorST             Decimal?          @db.Decimal(14, 2)
  mva                 Decimal?          @db.Decimal(8, 4)
  // FCP — Fundo de Combate à Pobreza
  valorFCP            Decimal?          @db.Decimal(14, 2)
  aliquotaFCP         Decimal?          @db.Decimal(8, 4)
  valorFCPST          Decimal?          @db.Decimal(14, 2)
  aliquotaFCPST       Decimal?          @db.Decimal(8, 4)
  dadosOriginais      Json?

  @@index([tenantId, empresaId, tributo])
  @@index([tenantId, empresaId, entradaFiscalItemId])
}

model RegraTributaria {
  id                    String             @id @default(cuid())
  tenantId              String
  empresaId             String?
  empresa               Empresa?           @relation(fields: [empresaId], references: [id])
  produtosFiscais       ProdutoFiscal[]
  nome                  String
  tributo               TipoTributo
  operacao              TipoOperacaoFiscal
  ufOrigem              String?
  ufDestino             String?
  regimeEmpresa         String?
  ncm                   String?
  cest                  String?
  cfop                  String?
  cst                   String?
  csosn                 String?
  cClassTrib            String?
  codigoBeneficioFiscal String?
  aliquota              Decimal?           @db.Decimal(8, 4)
  reducaoBase           Decimal?           @db.Decimal(8, 4)
  diferimento           Decimal?           @db.Decimal(8, 4)
  creditoPresumido      Decimal?           @db.Decimal(8, 4)
  // Modalidade BC ICMS: 0-Margem, 1-Pauta, 2-Preço Tabelado, 3-Preço Efetivo
  modBC                 Int?
  // ICMS-ST (Substituição Tributária)
  mva                   Decimal?           @db.Decimal(8, 4)
  reducaoBaseST         Decimal?           @db.Decimal(8, 4)
  aliquotaST            Decimal?           @db.Decimal(8, 4)
  // FCP — Fundo de Combate à Pobreza
