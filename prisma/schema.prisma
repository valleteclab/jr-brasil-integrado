generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum StatusEmpresa {
  ATIVA
  INATIVA
  BLOQUEADA
}

enum StatusCliente {
  PENDENTE_APROVACAO
  ATIVO
  BLOQUEADO
  INATIVO
}

enum StatusPedido {
  RASCUNHO
  AGUARDANDO_PAGAMENTO
  AGUARDANDO_NOTA
  SEPARACAO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum StatusOrcamento {
  RASCUNHO
  EM_ANALISE
  AGUARDANDO_CLIENTE
  APROVADO
  EXPIRADO
  REJEITADO
  CONVERTIDO
}

enum StatusOrdemServico {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECAS
  FINALIZADA_NAO_FATURADA
  FATURADA
  CANCELADA
}

enum TipoMovimentoEstoque {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE
  RESERVA
  LIBERACAO_RESERVA
}

enum StatusFinanceiro {
  ABERTO
  VENCIDO
  PAGO
  CANCELADO
}

enum StatusNotaFiscal {
  RASCUNHO
  AUTORIZADA
  CANCELADA
  REJEITADA
}

model Tenant {
  id           String           @id @default(cuid())
  nome         String
  slug         String           @unique
  ativo        Boolean          @default(true)
  empresas     Empresa[]
  vinculos     UsuarioVinculo[]
  perfis       Perfil[]
  auditorias   Auditoria[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt
}

model Empresa {
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  razaoSocial         String
  nomeFantasia        String?
  cnpj                String
  inscricaoEstadual   String?
  inscricaoMunicipal  String?
  status              StatusEmpresa     @default(ATIVA)
  matriz              Boolean           @default(false)
  vinculos            UsuarioVinculo[]
  clientes            Cliente[]
  fornecedores        Fornecedor[]
  categorias          ProdutoCategoria[]
  marcas              ProdutoMarca[]
  produtos            Produto[]
  tabelasPreco        TabelaPreco[]
  depositos           Deposito[]
  pedidosVenda        PedidoVenda[]
  orcamentos          Orcamento[]
  ordensServico       OrdemServico[]
  pedidosCompra       PedidoCompra[]
  contasPagar         ContaPagar[]
  contasReceber       ContaReceber[]
  notasFiscais        NotaFiscal[]
  auditorias          Auditoria[]
  criadoEm            DateTime          @default(now())
  atualizadoEm        DateTime          @updatedAt

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

model Usuario {
  id           String           @id @default(cuid())
  nome         String
  email        String           @unique
  senhaHash    String
  status       StatusUsuario    @default(ATIVO)
  vinculos     UsuarioVinculo[]
  auditorias   Auditoria[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt
}

model UsuarioVinculo {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String?
  usuarioId    String
  perfilId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  perfil       Perfil   @relation(fields: [perfilId], references: [id])
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tenantId, empresaId, usuarioId, perfilId])
  @@index([tenantId, empresaId])
  @@index([usuarioId])
}

model Perfil {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  nome         String
  descricao    String?
  vinculos     UsuarioVinculo[]
  permissoes   Permissao[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model Permissao {
  id       String   @id @default(cuid())
  tenantId String
  perfilId String
  modulo   String
  acao     String
  perfil   Perfil   @relation(fields: [perfilId], references: [id])
  criadoEm DateTime @default(now())

  @@unique([tenantId, modulo, acao, perfilId])
  @@index([tenantId])
}

model Auditoria {
  id         String   @id @default(cuid())
  tenantId   String
  empresaId  String?
  usuarioId  String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  empresa    Empresa? @relation(fields: [empresaId], references: [id])
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  entidade   String
  entidadeId String
  acao       String
  payload    Json?
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  @@index([tenantId, empresaId])
  @@index([entidade, entidadeId])
}

model Cliente {
  id                String            @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  razaoSocial       String
  nomeFantasia      String?
  documento         String
  inscricaoEstadual String?
  status            StatusCliente     @default(PENDENTE_APROVACAO)
  segmento          String?
  limiteCredito     Decimal           @default(0) @db.Decimal(14, 2)
  creditoUsado      Decimal           @default(0) @db.Decimal(14, 2)
  condicaoPagamento String?
  tabelaPrecoId     String?
  tabelaPreco       TabelaPreco?      @relation(fields: [tabelaPrecoId], references: [id])
  contatos          ClienteContato[]
  enderecos         ClienteEndereco[]
  pedidosVenda      PedidoVenda[]
  orcamentos        Orcamento[]
  ordensServico     OrdemServico[]
  contasReceber     ContaReceber[]
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt

  @@unique([tenantId, documento])
  @@index([tenantId, empresaId])
}

model ClienteContato {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  nome         String
  email        String?
  telefone     String?
  whatsapp     String?
  cargo        String?
  principal    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model ClienteEndereco {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  apelido      String
  cep          String
  logradouro   String
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String
  uf           String
  referencia   String?
  padrao       Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model TabelaPreco {
  id           String            @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa           @relation(fields: [empresaId], references: [id])
  nome         String
  descricao    String?
  clientes     Cliente[]
  itens        TabelaPrecoItem[]
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model TabelaPrecoItem {
  id                String      @id @default(cuid())
  tenantId          String
  empresaId         String
  tabelaPrecoId     String
  produtoId         String
  tabelaPreco       TabelaPreco @relation(fields: [tabelaPrecoId], references: [id])
  produto           Produto     @relation(fields: [produtoId], references: [id])
  preco             Decimal     @db.Decimal(14, 2)
  quantidadeMinima  Int         @default(1)

  @@unique([tenantId, tabelaPrecoId, produtoId, quantidadeMinima])
  @@index([tenantId, empresaId])
}

model ProdutoCategoria {
  id               String             @id @default(cuid())
  tenantId         String
  empresaId        String
  empresa          Empresa            @relation(fields: [empresaId], references: [id])
  nome             String
  slug             String
  categoriaPaiId   String?
  categoriaPai     ProdutoCategoria?  @relation("ArvoreCategoria", fields: [categoriaPaiId], references: [id])
  categoriasFilhas ProdutoCategoria[] @relation("ArvoreCategoria")
  produtos         Produto[]
  criadoEm         DateTime           @default(now())
  atualizadoEm     DateTime           @updatedAt

  @@unique([tenantId, empresaId, slug])
  @@index([tenantId, empresaId])
}

model ProdutoMarca {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  nome         String
  produtos     Produto[]
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model Produto {
  id                 String              @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa             @relation(fields: [empresaId], references: [id])
  sku                String
  nome               String
  descricao          String?
  descricaoComercial String?
  categoriaId        String
  marcaId            String?
  categoria          ProdutoCategoria    @relation(fields: [categoriaId], references: [id])
  marca              ProdutoMarca?       @relation(fields: [marcaId], references: [id])
  unidade            String              @default("UN")
  pesoKg             Decimal?            @db.Decimal(10, 3)
  ncm                String?
  cest               String?
  cfop               String?
  origem             String?
  precoCusto         Decimal             @default(0) @db.Decimal(14, 2)
  precoVenda         Decimal             @default(0) @db.Decimal(14, 2)
  quantidadeMinima   Int                 @default(1)
  ativo              Boolean             @default(true)
  visivelEcommerce   Boolean             @default(true)
  imagens            ProdutoImagem[]
  aplicacoes         ProdutoAplicacao[]
  saldosEstoque      EstoqueSaldo[]
  movimentosEstoque  EstoqueMovimento[]
  itensPedidoVenda   PedidoVendaItem[]
  itensOrcamento     OrcamentoItem[]
  pecasServico       OrdemServicoPeca[]
  itensCompra        PedidoCompraItem[]
  itensPreco         TabelaPrecoItem[]
  criadoEm           DateTime            @default(now())
  atualizadoEm       DateTime            @updatedAt

  @@unique([tenantId, empresaId, sku])
  @@index([tenantId, empresaId])
}

model ProdutoImagem {
  id        String  @id @default(cuid())
  tenantId  String
  empresaId String
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  url       String
  textoAlt  String?
  ordem     Int     @default(0)

  @@index([tenantId, empresaId])
}

model ProdutoAplicacao {
  id          String  @id @default(cuid())
  tenantId    String
  empresaId   String
  produtoId   String
  produto     Produto @relation(fields: [produtoId], references: [id])
  marca       String?
  modelo      String?
  anoFaixa    String?
  observacoes String?

  @@index([tenantId, empresaId])
}

model Deposito {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  nome         String
  uf           String?
  ativo        Boolean            @default(true)
  saldos       EstoqueSaldo[]
  movimentos   EstoqueMovimento[]
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model EstoqueSaldo {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  produto      Produto  @relation(fields: [produtoId], references: [id])
  deposito     Deposito @relation(fields: [depositoId], references: [id])
  quantidade   Int      @default(0)
  reservado    Int      @default(0)
  minimo       Int      @default(0)
  atualizadoEm DateTime @updatedAt

  @@unique([tenantId, empresaId, produtoId, depositoId])
  @@index([tenantId, empresaId])
}

model EstoqueMovimento {
  id            String               @id @default(cuid())
  tenantId      String
  empresaId     String
  produtoId     String
  depositoId    String
  produto       Produto              @relation(fields: [produtoId], references: [id])
  deposito      Deposito             @relation(fields: [depositoId], references: [id])
  tipo          TipoMovimentoEstoque
  quantidade    Int
  custoUnitario Decimal?             @db.Decimal(14, 2)
  origem        String?
  origemId      String?
  observacoes   String?
  criadoEm      DateTime             @default(now())

  @@index([tenantId, empresaId])
}

model PedidoVenda {
  id                String            @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  numero            String
  clienteId         String
  cliente           Cliente           @relation(fields: [clienteId], references: [id])
  canal             String
  status            StatusPedido      @default(RASCUNHO)
  subtotal          Decimal           @default(0) @db.Decimal(14, 2)
  desconto          Decimal           @default(0) @db.Decimal(14, 2)
  frete             Decimal           @default(0) @db.Decimal(14, 2)
  total             Decimal           @default(0) @db.Decimal(14, 2)
  condicaoPagamento String?
  observacoes       String?
  itens             PedidoVendaItem[]
  contasReceber     ContaReceber[]
  notasFiscais      NotaFiscal[]
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model PedidoVendaItem {
  id            String      @id @default(cuid())
  tenantId      String
  empresaId     String
  pedidoVendaId String
  produtoId     String
  pedidoVenda   PedidoVenda @relation(fields: [pedidoVendaId], references: [id])
  produto       Produto     @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Decimal     @db.Decimal(14, 2)
  desconto      Decimal     @default(0) @db.Decimal(14, 2)
  total         Decimal     @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model Orcamento {
  id                 String          @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa         @relation(fields: [empresaId], references: [id])
  numero             String
  clienteId          String
  cliente            Cliente         @relation(fields: [clienteId], references: [id])
  canal              String
  status             StatusOrcamento @default(EM_ANALISE)
  validoAte          DateTime?
  observacaoVendedor String?
  subtotal           Decimal         @default(0) @db.Decimal(14, 2)
  total              Decimal         @default(0) @db.Decimal(14, 2)
  itens              OrcamentoItem[]
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model OrcamentoItem {
  id            String    @id @default(cuid())
  tenantId      String
  empresaId     String
  orcamentoId   String
  produtoId     String
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id])
  produto       Produto   @relation(fields: [produtoId], references: [id])
  quantidade    Int
  precoUnitario Decimal   @db.Decimal(14, 2)
  total         Decimal   @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model OrdemServico {
  id             String                @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa               @relation(fields: [empresaId], references: [id])
  numero         String
  clienteId      String
  cliente        Cliente               @relation(fields: [clienteId], references: [id])
  status         StatusOrdemServico    @default(ABERTA)
  equipamento    String
  placaOuSerial  String?
  diagnostico    String?
  previsaoEm     DateTime?
  servicos       OrdemServicoMaoObra[]
  pecas          OrdemServicoPeca[]
  contasReceber  ContaReceber[]
  notasFiscais   NotaFiscal[]
  criadoEm       DateTime              @default(now())
  atualizadoEm   DateTime              @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model OrdemServicoMaoObra {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  ordemServicoId String
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id])
  descricao      String
  horas          Decimal      @db.Decimal(8, 2)
  valorHora      Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model OrdemServicoPeca {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  ordemServicoId String
  produtoId      String
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id])
  produto        Produto      @relation(fields: [produtoId], references: [id])
  quantidade     Int
  precoUnitario  Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model Fornecedor {
  id                String         @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa        @relation(fields: [empresaId], references: [id])
  razaoSocial       String
  nomeFantasia      String?
  documento         String
  email             String?
  telefone          String?
  cidade            String?
  uf                String?
  condicaoPagamento String?
  ativo             Boolean        @default(true)
  pedidosCompra     PedidoCompra[]
  contasPagar       ContaPagar[]
  criadoEm          DateTime       @default(now())
  atualizadoEm      DateTime       @updatedAt

  @@unique([tenantId, empresaId, documento])
  @@index([tenantId, empresaId])
}

model PedidoCompra {
  id             String             @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa            @relation(fields: [empresaId], references: [id])
  numero         String
  fornecedorId   String
  fornecedor     Fornecedor         @relation(fields: [fornecedorId], references: [id])
  status         String             @default("RASCUNHO")
  previsaoEm     DateTime?
  frete          Decimal            @default(0) @db.Decimal(14, 2)
  total          Decimal            @default(0) @db.Decimal(14, 2)
  itens          PedidoCompraItem[]
  contasPagar    ContaPagar[]
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId])
}

model PedidoCompraItem {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  pedidoCompraId String
  produtoId      String
  pedidoCompra   PedidoCompra @relation(fields: [pedidoCompraId], references: [id])
  produto        Produto      @relation(fields: [produtoId], references: [id])
  quantidade     Int
  custoUnitario  Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model ContaPagar {
  id             String           @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  fornecedorId   String?
  pedidoCompraId String?
  fornecedor     Fornecedor?      @relation(fields: [fornecedorId], references: [id])
  pedidoCompra   PedidoCompra?    @relation(fields: [pedidoCompraId], references: [id])
  descricao      String
  vencimento     DateTime
  valor          Decimal          @db.Decimal(14, 2)
  status         StatusFinanceiro @default(ABERTO)
  pagoEm         DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@index([tenantId, empresaId, status])
}

model ContaReceber {
  id             String           @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  clienteId      String
  pedidoVendaId  String?
  ordemServicoId String?
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  pedidoVenda    PedidoVenda?     @relation(fields: [pedidoVendaId], references: [id])
  ordemServico   OrdemServico?    @relation(fields: [ordemServicoId], references: [id])
  descricao      String
  vencimento     DateTime
  valor          Decimal          @db.Decimal(14, 2)
  status         StatusFinanceiro @default(ABERTO)
  pagoEm         DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@index([tenantId, empresaId, status])
}

model NotaFiscal {
  id             String           @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  numero         String?
  serie          String?
  chaveAcesso    String?
  status         StatusNotaFiscal @default(RASCUNHO)
  clienteId      String?
  pedidoVendaId  String?
  ordemServicoId String?
  pedidoVenda    PedidoVenda?     @relation(fields: [pedidoVendaId], references: [id])
  ordemServico   OrdemServico?    @relation(fields: [ordemServicoId], references: [id])
  total          Decimal          @default(0) @db.Decimal(14, 2)
  xmlUrl         String?
  danfeUrl       String?
  emitidaEm      DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, status])
}
