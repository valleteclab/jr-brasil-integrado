  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  clienteId      String
  pedidoVendaId  String?
  ordemServicoId String?
  notaFiscalId   String?
  cliente        Cliente          @relation(fields: [clienteId], references: [id])
  pedidoVenda    PedidoVenda?     @relation(fields: [pedidoVendaId], references: [id])
  ordemServico   OrdemServico?    @relation(fields: [ordemServicoId], references: [id])
  notaFiscal     NotaFiscal?      @relation(fields: [notaFiscalId], references: [id])
  descricao      String
  numeroDocumento String?
  origem         String?
  formaPagamento String?
  vencimento     DateTime
  valor          Decimal          @db.Decimal(14, 2)
  valorPago      Decimal          @default(0) @db.Decimal(14, 2)
  juros          Decimal          @default(0) @db.Decimal(14, 2)
  multa          Decimal          @default(0) @db.Decimal(14, 2)
  descontoBaixa  Decimal          @default(0) @db.Decimal(14, 2)
  observacoes    String?
  contaBancariaId String?
  contaBancaria  ContaBancaria?   @relation(fields: [contaBancariaId], references: [id])
  movimentos     MovimentoFinanceiro[]
  status         StatusFinanceiro @default(ABERTO)
  pagoEm         DateTime?
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, clienteId, vencimento])
}

model NotaFiscal {
  id             String           @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa          @relation(fields: [empresaId], references: [id])
  modelo         ModeloFiscal     @default(NFE)
  finalidade     FinalidadeNfe    @default(NORMAL)
  ambiente       AmbienteFiscal   @default(HOMOLOGACAO)
  provedor       ProvedorFiscal   @default(MANUAL)
  numero         String?
  serie          String?
  chaveAcesso    String?
  protocolo      String?
  reciboLote     String?
  providerRef    String?
  status         StatusNotaFiscal @default(RASCUNHO)
  naturezaOperacao String?
  clienteId      String?
  pedidoVendaId  String?
  ordemServicoId String?
  notaOrigemId   String?
  chaveReferenciada String?
  cliente        Cliente?         @relation(fields: [clienteId], references: [id])
  pedidoVenda    PedidoVenda?     @relation(fields: [pedidoVendaId], references: [id])
  ordemServico   OrdemServico?    @relation(fields: [ordemServicoId], references: [id])
  notaOrigem     NotaFiscal?      @relation("NotaDevolucao", fields: [notaOrigemId], references: [id])
  devolucoes     NotaFiscal[]     @relation("NotaDevolucao")
  destinatarioNome     String?
  destinatarioDocumento String?
  destinatarioIe       String?
  destinatarioEmail    String?
  valorProdutos  Decimal          @default(0) @db.Decimal(14, 2)
  valorServicos  Decimal          @default(0) @db.Decimal(14, 2)
  valorDesconto  Decimal          @default(0) @db.Decimal(14, 2)
  valorFrete     Decimal          @default(0) @db.Decimal(14, 2)
  valorSeguro    Decimal          @default(0) @db.Decimal(14, 2)
  outrasDespesas Decimal          @default(0) @db.Decimal(14, 2)
  valorIcms      Decimal          @default(0) @db.Decimal(14, 2)
  valorIcmsSt    Decimal          @default(0) @db.Decimal(14, 2)
  valorFcp       Decimal          @default(0) @db.Decimal(14, 2)
  valorIpi       Decimal          @default(0) @db.Decimal(14, 2)
  valorPis       Decimal          @default(0) @db.Decimal(14, 2)
  valorCofins    Decimal          @default(0) @db.Decimal(14, 2)
  valorIss       Decimal          @default(0) @db.Decimal(14, 2)
  valorTotalTributos Decimal      @default(0) @db.Decimal(14, 2)
  issRetido      Boolean          @default(false)
  valorIrRetido     Decimal       @default(0) @db.Decimal(14, 2)
  valorPisRetido    Decimal       @default(0) @db.Decimal(14, 2)
  valorCofinsRetido Decimal       @default(0) @db.Decimal(14, 2)
  valorCsllRetido   Decimal       @default(0) @db.Decimal(14, 2)
  valorInssRetido   Decimal       @default(0) @db.Decimal(14, 2)
  valorRetidoTotal  Decimal       @default(0) @db.Decimal(14, 2)
  valorLiquido      Decimal       @default(0) @db.Decimal(14, 2)
  total          Decimal          @default(0) @db.Decimal(14, 2)
  formaPagamento String?
  condicaoPagamento String?
  informacoesComplementares String?
  motivo         String?
  xml            String?
  xmlUrl         String?
  danfeUrl       String?
  emitidaEm      DateTime?
  autorizadaEm   DateTime?
  canceladaEm    DateTime?
  itens          NotaFiscalItem[]
  eventos        NotaFiscalEvento[]
  contasReceber  ContaReceber[]
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@unique([tenantId, empresaId, modelo, serie, numero])
  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, modelo, status])
  @@index([tenantId, empresaId, clienteId])
}

