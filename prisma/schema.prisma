generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum CustomerStatus {
  PENDING_APPROVAL
  ACTIVE
  BLOCKED
  INACTIVE
}

enum OrderStatus {
  DRAFT
  WAITING_PAYMENT
  WAITING_INVOICE
  PICKING
  SHIPPED
  DELIVERED
  CANCELED
}

enum QuoteStatus {
  DRAFT
  IN_REVIEW
  WAITING_CUSTOMER
  APPROVED
  EXPIRED
  REJECTED
  CONVERTED
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  FINISHED_NOT_INVOICED
  INVOICED
  CANCELED
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
  RESERVATION
  RELEASE_RESERVATION
}

enum FinancialStatus {
  OPEN
  OVERDUE
  PAID
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  AUTHORIZED
  CANCELED
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  module    String
  action    String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@unique([module, action, roleId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  entity    String
  entityId  String
  action    String
  payload   Json?
  createdAt DateTime @default(now())
}

model Customer {
  id              String         @id @default(cuid())
  legalName       String
  tradeName       String?
  document        String         @unique
  stateRegistration String?
  status          CustomerStatus @default(PENDING_APPROVAL)
  segment         String?
  creditLimit     Decimal        @default(0) @db.Decimal(14, 2)
  creditUsed      Decimal        @default(0) @db.Decimal(14, 2)
  paymentTerms    String?
  priceTableId    String?
  priceTable      PriceTable?    @relation(fields: [priceTableId], references: [id])
  contacts        CustomerContact[]
  addresses       CustomerAddress[]
  orders          SalesOrder[]
  quotes          Quote[]
  serviceOrders   ServiceOrder[]
  receivables     AccountsReceivable[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CustomerContact {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  name       String
  email      String?
  phone      String?
  whatsapp   String?
  role       String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  label      String
  zipCode    String
  street     String
  number     String?
  complement String?
  district   String?
  city       String
  state      String
  reference  String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PriceTable {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  customers   Customer[]
  items       PriceTableItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model PriceTableItem {
  id           String     @id @default(cuid())
  priceTableId String
  productId    String
  priceTable   PriceTable @relation(fields: [priceTableId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
  price        Decimal    @db.Decimal(14, 2)
  minQuantity  Int        @default(1)

  @@unique([priceTableId, productId, minQuantity])
}

model ProductCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  parentId    String?
  parent      ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ProductBrand {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id              String             @id @default(cuid())
  sku             String             @unique
  name            String
  description     String?
  commercialDescription String?
  categoryId      String
  brandId         String?
  category        ProductCategory    @relation(fields: [categoryId], references: [id])
  brand           ProductBrand?      @relation(fields: [brandId], references: [id])
  unit            String             @default("UN")
  weightKg        Decimal?           @db.Decimal(10, 3)
  ncm             String?
  cest            String?
  cfop            String?
  origin          String?
  costPrice       Decimal            @default(0) @db.Decimal(14, 2)
  salePrice       Decimal            @default(0) @db.Decimal(14, 2)
  minQuantity     Int                @default(1)
  isActive        Boolean            @default(true)
  ecommerceVisible Boolean           @default(true)
  images          ProductImage[]
  stockBalances   StockBalance[]
  stockMovements  StockMovement[]
  orderItems      SalesOrderItem[]
  quoteItems      QuoteItem[]
  serviceParts    ServiceOrderPart[]
  purchaseItems   PurchaseOrderItem[]
  priceItems      PriceTableItem[]
  applications    ProductApplication[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  url       String
  alt       String?
  sortOrder Int      @default(0)
}

model ProductApplication {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])
  brand     String?
  model     String?
  yearRange String?
  notes     String?
}

model Warehouse {
  id             String          @id @default(cuid())
  name           String
  state          String?
  isActive       Boolean         @default(true)
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model StockBalance {
  id         String    @id @default(cuid())
  productId  String
  warehouseId String
  product    Product   @relation(fields: [productId], references: [id])
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id])
  quantity   Int       @default(0)
  reserved   Int       @default(0)
  minimum    Int       @default(0)
  updatedAt  DateTime  @updatedAt

  @@unique([productId, warehouseId])
}

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  product     Product           @relation(fields: [productId], references: [id])
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id])
  type        StockMovementType
  quantity    Int
  unitCost    Decimal?          @db.Decimal(14, 2)
  source      String?
  sourceId    String?
  notes       String?
  createdAt   DateTime          @default(now())
}

model SalesOrder {
  id          String           @id @default(cuid())
  number      String           @unique
  customerId  String
  customer    Customer         @relation(fields: [customerId], references: [id])
  channel     String
  status      OrderStatus      @default(DRAFT)
  subtotal    Decimal          @default(0) @db.Decimal(14, 2)
  discount    Decimal          @default(0) @db.Decimal(14, 2)
  shippingFee Decimal          @default(0) @db.Decimal(14, 2)
  total       Decimal          @default(0) @db.Decimal(14, 2)
  paymentTerms String?
  notes       String?
  items       SalesOrderItem[]
  receivables AccountsReceivable[]
  invoices    FiscalInvoice[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model SalesOrderItem {
  id        String     @id @default(cuid())
  orderId   String
  productId String
  order     SalesOrder @relation(fields: [orderId], references: [id])
  product   Product    @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal    @db.Decimal(14, 2)
  discount  Decimal    @default(0) @db.Decimal(14, 2)
  total     Decimal    @db.Decimal(14, 2)
}

model Quote {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  channel     String
  status      QuoteStatus @default(IN_REVIEW)
  validUntil  DateTime?
  sellerNote  String?
  subtotal    Decimal     @default(0) @db.Decimal(14, 2)
  total       Decimal     @default(0) @db.Decimal(14, 2)
  items       QuoteItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  productId String
  quote     Quote   @relation(fields: [quoteId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(14, 2)
  total     Decimal @db.Decimal(14, 2)
}

model ServiceOrder {
  id          String             @id @default(cuid())
  number      String             @unique
  customerId  String
  customer    Customer           @relation(fields: [customerId], references: [id])
  status      ServiceOrderStatus @default(OPEN)
  equipment   String
  plateOrSerial String?
  diagnosis   String?
  expectedAt  DateTime?
  laborItems  ServiceOrderLabor[]
  parts       ServiceOrderPart[]
  receivables AccountsReceivable[]
  invoices    FiscalInvoice[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ServiceOrderLabor {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  description    String
  hours          Decimal      @db.Decimal(8, 2)
  hourlyRate     Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)
}

model ServiceOrderPart {
  id             String       @id @default(cuid())
  serviceOrderId String
  productId      String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int
  unitPrice      Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)
}

model Supplier {
  id          String          @id @default(cuid())
  legalName   String
  tradeName   String?
  document    String          @unique
  email       String?
  phone       String?
  city        String?
  state       String?
  paymentTerms String?
  isActive    Boolean         @default(true)
  purchaseOrders PurchaseOrder[]
  payables    AccountsPayable[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  number      String              @unique
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  status      String              @default("DRAFT")
  expectedAt  DateTime?
  shippingFee Decimal             @default(0) @db.Decimal(14, 2)
  total       Decimal             @default(0) @db.Decimal(14, 2)
  items       PurchaseOrderItem[]
  payables    AccountsPayable[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Int
  unitCost        Decimal       @db.Decimal(14, 2)
  total           Decimal       @db.Decimal(14, 2)
}

model AccountsPayable {
  id              String          @id @default(cuid())
  supplierId      String?
  purchaseOrderId String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  description     String
  dueDate         DateTime
  amount          Decimal         @db.Decimal(14, 2)
  status          FinancialStatus @default(OPEN)
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model AccountsReceivable {
  id             String          @id @default(cuid())
  customerId     String
  salesOrderId   String?
  serviceOrderId String?
  customer       Customer        @relation(fields: [customerId], references: [id])
  salesOrder     SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  serviceOrder   ServiceOrder?   @relation(fields: [serviceOrderId], references: [id])
  description    String
  dueDate        DateTime
  amount         Decimal         @db.Decimal(14, 2)
  status         FinancialStatus @default(OPEN)
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model FiscalInvoice {
  id             String        @id @default(cuid())
  number         String?
  series         String?
  accessKey      String?       @unique
  status         InvoiceStatus @default(DRAFT)
  customerId     String?
  salesOrderId   String?
  serviceOrderId String?
  salesOrder     SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  total          Decimal       @default(0) @db.Decimal(14, 2)
  xmlUrl         String?
  danfeUrl       String?
  issuedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}
