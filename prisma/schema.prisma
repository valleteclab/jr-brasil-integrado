model PedidoVenda {
  id                  String              @id @default(cuid())
  tenantId            String
  empresaId           String
  empresa             Empresa             @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando o pedido foi criado. Isola dados de homologação dos de produção.
  ambiente            AmbienteFiscal      @default(HOMOLOGACAO)
  numero              String
  clienteId           String?
  cliente             Cliente?            @relation(fields: [clienteId], references: [id])
  depositoId          String?
  deposito            Deposito?           @relation(fields: [depositoId], references: [id])
  canal               String
  status              StatusPedido        @default(RASCUNHO)
  naturezaOperacao    String?
  // Nome livre do vendedor (legado/exibição). vendedorId é o vínculo para comissão.
  vendedor            String?
  vendedorId          String?
  vendedorRef         Vendedor?           @relation(fields: [vendedorId], references: [id])
  comissao            ComissaoVenda?
  subtotal            Decimal             @default(0) @db.Decimal(14, 2)
  desconto            Decimal             @default(0) @db.Decimal(14, 2)
  frete               Decimal             @default(0) @db.Decimal(14, 2)
  total               Decimal             @default(0) @db.Decimal(14, 2)
  condicaoPagamento   String?
  formaPagamento      String?
  /// Venda no BOLETO: opções escolhidas no atendimento (contaBancariaId, parcelas, datas[]) —
  /// consumidas na confirmação para gerar as parcelas e registrar os boletos no banco certo.
  boletoOpcoes        Json?
  observacoes         String?
  observacoesInternas String?
  confirmadoEm        DateTime?
  faturadoEm          DateTime?
  canceladoEm         DateTime?
  itens               PedidoVendaItem[]
  contasReceber       ContaReceber[]
  notasFiscais        NotaFiscal[]
  pagamentos          PagamentoVenda[]
  caixaMovimentos     CaixaMovimento[]
  retiradas           ExpedicaoRetirada[]
  origemOrcamentoId   String?
  criadoEm            DateTime            @default(now())
  atualizadoEm        DateTime            @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model PedidoVendaItem {
  id            String      @id @default(cuid())
  tenantId      String
  empresaId     String
  pedidoVendaId String
  produtoId     String
  pedidoVenda   PedidoVenda @relation(fields: [pedidoVendaId], references: [id])
  produto       Produto     @relation(fields: [produtoId], references: [id])
  quantidade    Decimal     @db.Decimal(14, 4)
  precoUnitario Decimal     @db.Decimal(14, 2)
  // Origem do preço aplicado pelo vendedor: VISTA (tabela à vista), PRAZO (tabela a prazo)
  // ou MANUAL (digitado na venda) — auditoria da formação de preço. null = legado (à vista).
  tipoPreco     String?
  custoUnitario Decimal     @default(0) @db.Decimal(14, 4)
  desconto      Decimal     @default(0) @db.Decimal(14, 2)
  total         Decimal     @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model Orcamento {
  id                 String          @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa         @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando o orçamento foi criado.
  ambiente           AmbienteFiscal  @default(HOMOLOGACAO)
  numero             String
  clienteId          String
  cliente            Cliente         @relation(fields: [clienteId], references: [id])
  canal              String
  status             StatusOrcamento @default(EM_ANALISE)
  validoAte          DateTime?
  observacaoVendedor String?
  vendedor           String?
  vendedorId         String?
  vendedorRef        Vendedor?       @relation(fields: [vendedorId], references: [id])
  condicaoPagamento  String?
  formaPagamento     String?
  desconto           Decimal         @default(0) @db.Decimal(14, 2)
  subtotal           Decimal         @default(0) @db.Decimal(14, 2)
  total              Decimal         @default(0) @db.Decimal(14, 2)
  pedidoGeradoId     String?
  aprovadoEm         DateTime?
  itens              OrcamentoItem[]
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model OrcamentoItem {
  id            String    @id @default(cuid())
  tenantId      String
  empresaId     String
  orcamentoId   String
  produtoId     String
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id])
  produto       Produto   @relation(fields: [produtoId], references: [id])
  quantidade    Decimal   @db.Decimal(14, 4)
  precoUnitario Decimal   @db.Decimal(14, 2)
  total         Decimal   @db.Decimal(14, 2)

  @@index([tenantId, empresaId])
}

model OrdemServico {
  id                String                @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa               @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando a OS foi criada.
  ambiente          AmbienteFiscal        @default(HOMOLOGACAO)
  numero            String
  clienteId         String
  cliente           Cliente               @relation(fields: [clienteId], references: [id])
  status            StatusOrdemServico    @default(ABERTA)
  equipamento       String
  placaOuSerial     String?
  /// KM / horímetro do veículo/equipamento na entrada (garantia e histórico).
  km                String?
  diagnostico       String?
  problemaRelatado  String?
  depositoId        String?
  previsaoEm        DateTime?
  /// Técnico responsável pela OS (o dono do serviço). Apontamentos podem ser de vários técnicos.
  tecnicoResponsavelId String?
  tecnicoResponsavel   Tecnico?           @relation("OsResponsavel", fields: [tecnicoResponsavelId], references: [id])
  totalServicos     Decimal               @default(0) @db.Decimal(14, 2)
  totalPecas        Decimal               @default(0) @db.Decimal(14, 2)
  desconto          Decimal               @default(0) @db.Decimal(14, 2)
  total             Decimal               @default(0) @db.Decimal(14, 2)
  condicaoPagamento String?
  formaPagamento    String?
  observacoes       String?
  faturadoEm        DateTime?
  servicos          OrdemServicoMaoObra[]
  pecas             OrdemServicoPeca[]
  apontamentos      OrdemServicoApontamento[]
  contasReceber     ContaReceber[]
  notasFiscais      NotaFiscal[]
  criadoEm          DateTime              @default(now())
  atualizadoEm      DateTime              @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model OrdemServicoMaoObra {
  id                 String       @id @default(cuid())
  tenantId           String
  empresaId          String
  ordemServicoId     String
  ordemServico       OrdemServico @relation(fields: [ordemServicoId], references: [id])
  descricao          String
  horas              Decimal      @db.Decimal(8, 2)
  valorHora          Decimal      @db.Decimal(14, 2)
  total              Decimal      @db.Decimal(14, 2)
  codigoServicoLc116 String?
  /// Técnico que executou este serviço (para produtividade por técnico).
  tecnicoId          String?
  tecnico            Tecnico?     @relation(fields: [tecnicoId], references: [id])

  @@index([tenantId, empresaId])
}

/// Cadastro de TÉCNICOS/MECÂNICOS da oficina. Podem ter login vinculado (usuarioId) para
/// atualizar as próprias OS (apontamentos). custoHora é interno (produtividade/custo real).
model Tecnico {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  empresa        Empresa      @relation(fields: [empresaId], references: [id])
  nome           String
  especialidade  String?
  telefone       String?
  custoHora      Decimal      @default(0) @db.Decimal(14, 2)
  /// Vínculo com o login do técnico (Usuario) — quem estiver logado é reconhecido como este técnico.
  usuarioId      String?      @unique
  ativo          Boolean      @default(true)
  apontamentos   OrdemServicoApontamento[]
  maoObras       OrdemServicoMaoObra[]
  ordensResponsavel OrdemServico[]        @relation("OsResponsavel")
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt

  @@index([tenantId, empresaId, ativo])
}

/// APONTAMENTO: o técnico registra O QUE FOI FEITO na OS (timeline de execução) + horas.
/// É o histórico de trabalho — separado da mão de obra cobrada (que vai na nota).
model OrdemServicoApontamento {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  ordemServicoId String
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id])
  tecnicoId      String
  tecnico        Tecnico      @relation(fields: [tecnicoId], references: [id])
  descricao      String
  horas          Decimal?     @db.Decimal(8, 2)
  /// Snapshot do status da OS no momento do apontamento (para a timeline).
  statusMomento  String?
  criadoEm       DateTime     @default(now())

  @@index([tenantId, empresaId, ordemServicoId])
}

model OrdemServicoPeca {
  id             String       @id @default(cuid())
  tenantId       String
  empresaId      String
  ordemServicoId String
  produtoId      String
  ordemServico   OrdemServico @relation(fields: [ordemServicoId], references: [id])
  produto        Produto      @relation(fields: [produtoId], references: [id])
  quantidade     Decimal      @db.Decimal(14, 4)
  precoUnitario  Decimal      @db.Decimal(14, 2)
  total          Decimal      @db.Decimal(14, 2)
  /// Peça a COMPRAR (não estava em estoque): fica esperando a nota de entrada chegar.
  aguardandoCompra Boolean    @default(false)
  /// Preenchido quando a peça chega (entrada fiscal do produto credita estoque) — avisa a oficina.
  chegouEm       DateTime?

  @@index([tenantId, empresaId])
  @@index([tenantId, empresaId, produtoId, aguardandoCompra])
}

model Fornecedor {
  id                 String              @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa             @relation(fields: [empresaId], references: [id])
  razaoSocial        String
  nomeFantasia       String?
  documento          String
  inscricaoEstadual  String?
  email              String?
  telefone           String?
  cep                String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?
  condicaoPagamento  String?
  observacoes        String?
  ativo              Boolean             @default(true)
  produtosVinculados ProdutoFornecedor[]
  entradasFiscais    EntradaFiscal[]
  pedidosCompra      PedidoCompra[]
  contasPagar        ContaPagar[]
  emprestimos        Emprestimo[]
  despesasRecorrentes DespesaRecorrente[]
