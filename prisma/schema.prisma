model PedidoVenda {
  id                  String              @id @default(cuid())
  tenantId            String
  empresaId           String
  empresa             Empresa             @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando o pedido foi criado. Isola dados de homologação dos de produção.
  ambiente            AmbienteFiscal      @default(HOMOLOGACAO)
  numero              String
  clienteId           String?
  cliente             Cliente?            @relation(fields: [clienteId], references: [id])
  depositoId          String?
  deposito            Deposito?           @relation(fields: [depositoId], references: [id])
  canal               String
  status              StatusPedido        @default(RASCUNHO)
  naturezaOperacao    String?
  // Nome livre do vendedor (legado/exibição). vendedorId é o vínculo para comissão.
  vendedor            String?
  vendedorId          String?
  vendedorRef         Vendedor?           @relation(fields: [vendedorId], references: [id])
  comissao            ComissaoVenda?
  subtotal            Decimal             @default(0) @db.Decimal(14, 2)
  desconto            Decimal             @default(0) @db.Decimal(14, 2)
  frete               Decimal             @default(0) @db.Decimal(14, 2)
  total               Decimal             @default(0) @db.Decimal(14, 2)
  condicaoPagamento   String?
  formaPagamento      String?
  /// Venda no BOLETO: opções escolhidas no atendimento (contaBancariaId, parcelas, datas[]) —
  /// consumidas na confirmação para gerar as parcelas e registrar os boletos no banco certo.
  boletoOpcoes        Json?
  observacoes         String?
  observacoesInternas String?
  confirmadoEm        DateTime?
  faturadoEm          DateTime?
  canceladoEm         DateTime?
  itens               PedidoVendaItem[]
  contasReceber       ContaReceber[]
  notasFiscais        NotaFiscal[]
  pagamentos          PagamentoVenda[]
  caixaMovimentos     CaixaMovimento[]
  retiradas           ExpedicaoRetirada[]
  origemOrcamentoId   String?
  criadoEm            DateTime            @default(now())
  atualizadoEm        DateTime            @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

