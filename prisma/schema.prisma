  CARTA_CORRECAO
  INUTILIZACAO
}

enum StatusEventoFiscal {
  PENDENTE
  PROCESSANDO
  AUTORIZADO
  REJEITADO
  ERRO
}

enum TipoMovimentoFinanceiro {
  CREDITO
  DEBITO
}

enum StatusInventario {
