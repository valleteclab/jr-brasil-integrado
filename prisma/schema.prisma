generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusUsuario {
  ATIVO
  INATIVO
}

enum StatusEmpresa {
  ATIVA
  INATIVA
  BLOQUEADA
}

enum StatusCliente {
  PENDENTE_APROVACAO
  ATIVO
  BLOQUEADO
  INATIVO
}

enum StatusPedido {
  RASCUNHO
  AGUARDANDO_PAGAMENTO
  AGUARDANDO_NOTA
  SEPARACAO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum StatusOrcamento {
  RASCUNHO
  EM_ANALISE
  AGUARDANDO_CLIENTE
  APROVADO
  EXPIRADO
  REJEITADO
  CONVERTIDO
}

enum StatusOrdemServico {
  ABERTA
  EM_ANDAMENTO
  AGUARDANDO_PECAS
  FINALIZADA_NAO_FATURADA
  FATURADA
  CANCELADA
}

enum TipoMovimentoEstoque {
  ENTRADA
  SAIDA
  TRANSFERENCIA
  AJUSTE
  ESTORNO
  RESERVA
  LIBERACAO_RESERVA
}

enum StatusFinanceiro {
  ABERTO
  VENCIDO
  PAGO
  CANCELADO
}

enum StatusNotaFiscal {
  RASCUNHO
  AUTORIZADA
  CANCELADA
  REJEITADA
}

enum TipoProduto {
  PRODUTO
  SERVICO
  KIT
  INSUMO
}

enum StatusXmlImportacao {
  RECEBIDO
  VALIDADO
  PROCESSADO
  REJEITADO
}

enum StatusEntradaFiscal {
  RASCUNHO
  AGUARDANDO_CONFERENCIA
  CONFERIDA
  ESTOQUE_PROCESSADO
  ESTORNADA
  CANCELADA
}

enum TipoTributo {
  ICMS
  IPI
  PIS
  COFINS
  ISS
  CBS
  IBS
  IS
}

enum TipoOperacaoFiscal {
  COMPRA
  VENDA
  DEVOLUCAO_COMPRA
  DEVOLUCAO_VENDA
  TRANSFERENCIA
  REMESSA
  RETORNO
}

enum ProvedorIa {
  OPENROUTER
}

model Tenant {
  id              String           @id @default(cuid())
  nome            String
  slug            String           @unique
  ativo           Boolean          @default(true)
  empresas        Empresa[]
  vinculos        UsuarioVinculo[]
  perfis          Perfil[]
  auditorias      Auditoria[]
  configuracoesIa ConfiguracaoIa[]
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
}

model Empresa {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String
  inscricaoEstadual  String?
  inscricaoMunicipal String?
  status             StatusEmpresa      @default(ATIVA)
  matriz             Boolean            @default(false)
  vinculos           UsuarioVinculo[]
  clientes           Cliente[]
  fornecedores       Fornecedor[]
  categorias         ProdutoCategoria[]
  marcas             ProdutoMarca[]
  produtos           Produto[]
  tabelasPreco       TabelaPreco[]
  depositos          Deposito[]
  pedidosVenda       PedidoVenda[]
  orcamentos         Orcamento[]
  ordensServico      OrdemServico[]
  pedidosCompra      PedidoCompra[]
  contasPagar        ContaPagar[]
  contasReceber      ContaReceber[]
  notasFiscais       NotaFiscal[]
  xmlImportacoes     XmlImportacao[]
  entradasFiscais    EntradaFiscal[]
  regrasTributarias  RegraTributaria[]
  configuracoesIa    ConfiguracaoIa[]
  auditorias         Auditoria[]
  criadoEm           DateTime           @default(now())
  atualizadoEm       DateTime           @updatedAt

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

model ConfiguracaoIa {
  id                 String     @id @default(cuid())
  tenantId           String
  empresaId          String
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
  provedor           ProvedorIa @default(OPENROUTER)
  ativo              Boolean    @default(false)
  modelo             String     @default("openai/gpt-4o-mini")
  chaveCriptografada String
  chaveFinal         String?
  observacoes        String?
  testadoEm          DateTime?
  ultimoErro         String?
  criadoEm           DateTime   @default(now())
  atualizadoEm       DateTime   @updatedAt

  @@unique([tenantId, empresaId, provedor])
  @@index([tenantId, empresaId])
}

model Usuario {
  id           String           @id @default(cuid())
  nome         String
  email        String           @unique
  senhaHash    String
  status       StatusUsuario    @default(ATIVO)
  vinculos     UsuarioVinculo[]
  auditorias   Auditoria[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt
}

model UsuarioVinculo {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String?
  usuarioId    String
  perfilId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  perfil       Perfil   @relation(fields: [perfilId], references: [id])
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tenantId, empresaId, usuarioId, perfilId])
  @@index([tenantId, empresaId])
  @@index([usuarioId])
}

model Perfil {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  nome         String
  descricao    String?
  vinculos     UsuarioVinculo[]
  permissoes   Permissao[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model Permissao {
  id       String   @id @default(cuid())
  tenantId String
  perfilId String
  modulo   String
  acao     String
  perfil   Perfil   @relation(fields: [perfilId], references: [id])
  criadoEm DateTime @default(now())

  @@unique([tenantId, modulo, acao, perfilId])
  @@index([tenantId])
}

model Auditoria {
  id         String   @id @default(cuid())
  tenantId   String
  empresaId  String?
  usuarioId  String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  empresa    Empresa? @relation(fields: [empresaId], references: [id])
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  entidade   String
  entidadeId String
  acao       String
  payload    Json?
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  @@index([tenantId, empresaId])
  @@index([entidade, entidadeId])
}

model Cliente {
  id                String            @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  razaoSocial       String
  nomeFantasia      String?
  documento         String
  inscricaoEstadual String?
  status            StatusCliente     @default(PENDENTE_APROVACAO)
  segmento          String?
  limiteCredito     Decimal           @default(0) @db.Decimal(14, 2)
  creditoUsado      Decimal           @default(0) @db.Decimal(14, 2)
  condicaoPagamento String?
  tabelaPrecoId     String?
  tabelaPreco       TabelaPreco?      @relation(fields: [tabelaPrecoId], references: [id])
  contatos          ClienteContato[]
  enderecos         ClienteEndereco[]
  pedidosVenda      PedidoVenda[]
  orcamentos        Orcamento[]
  ordensServico     OrdemServico[]
  contasReceber     ContaReceber[]
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt

  @@unique([tenantId, documento])
  @@index([tenantId, empresaId])
}

model ClienteContato {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  nome         String
  email        String?
  telefone     String?
  whatsapp     String?
  cargo        String?
  principal    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model ClienteEndereco {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  apelido      String
  cep          String
  logradouro   String
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String
  uf           String
  referencia   String?
  padrao       Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model TabelaPreco {
  id           String            @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa           @relation(fields: [empresaId], references: [id])
  nome         String
  descricao    String?
  clientes     Cliente[]
  itens        TabelaPrecoItem[]
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model TabelaPrecoItem {
  id               String      @id @default(cuid())
  tenantId         String
  empresaId        String
  tabelaPrecoId    String
  produtoId        String
  tabelaPreco      TabelaPreco @relation(fields: [tabelaPrecoId], references: [id])
  produto          Produto     @relation(fields: [produtoId], references: [id])
  preco            Decimal     @db.Decimal(14, 2)
  quantidadeMinima Int         @default(1)

  @@unique([tenantId, tabelaPrecoId, produtoId, quantidadeMinima])
  @@index([tenantId, empresaId])
}

model ProdutoCategoria {
  id               String             @id @default(cuid())
  tenantId         String
  empresaId        String
  empresa          Empresa            @relation(fields: [empresaId], references: [id])
  nome             String
  slug             String
  categoriaPaiId   String?
  categoriaPai     ProdutoCategoria?  @relation("ArvoreCategoria", fields: [categoriaPaiId], references: [id])
  categoriasFilhas ProdutoCategoria[] @relation("ArvoreCategoria")
  produtos         Produto[]
  criadoEm         DateTime           @default(now())
  atualizadoEm     DateTime           @updatedAt

  @@unique([tenantId, empresaId, slug])
  @@index([tenantId, empresaId])
}

model ProdutoMarca {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  nome         String
  produtos     Produto[]
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model Produto {
  id                       String              @id @default(cuid())
  tenantId                 String
  empresaId                String
  empresa                  Empresa             @relation(fields: [empresaId], references: [id])
  sku                      String
  nome                     String
  descricao                String?
  descricaoComercial       String?
  tipo                     TipoProduto         @default(PRODUTO)
  codigoOriginal           String?
  codigoFabricante         String?
  gtin                     String?
  categoriaId              String
  marcaId                  String?
  categoria                ProdutoCategoria    @relation(fields: [categoriaId], references: [id])
  marca                    ProdutoMarca?       @relation(fields: [marcaId], references: [id])
  unidade                  String              @default("UN")
  unidadeCompra            String              @default("UN")
  fatorConversaoCompra     Decimal             @default(1) @db.Decimal(14, 6)
  pesoKg                   Decimal?            @db.Decimal(10, 3)
  pesoBrutoKg              Decimal?            @db.Decimal(10, 3)
  alturaCm                 Decimal?            @db.Decimal(10, 3)
  larguraCm                Decimal?            @db.Decimal(10, 3)
  comprimentoCm            Decimal?            @db.Decimal(10, 3)
  ncm                      String?
  cest                     String?
  cfop                     String?
  origem                   String?
  precoCusto               Decimal             @default(0) @db.Decimal(14, 2)
  ultimoCusto              Decimal             @default(0) @db.Decimal(14, 2)
  custoMedio               Decimal             @default(0) @db.Decimal(14, 4)
  precoVenda               Decimal             @default(0) @db.Decimal(14, 2)
  precoMinimo              Decimal             @default(0) @db.Decimal(14, 2)
  margemAlvoPercentual     Decimal?            @db.Decimal(8, 4)
  quantidadeMinima         Int                 @default(1)
  controlaLote             Boolean             @default(false)
  controlaSerie            Boolean             @default(false)
  controlaValidade         Boolean             @default(false)
  permiteEstoqueNegativo   Boolean             @default(false)
  permiteVendaSobEncomenda Boolean             @default(false)
  ativoCompra              Boolean             @default(true)
  ativoVenda               Boolean             @default(true)
  ativo                    Boolean             @default(true)
  visivelEcommerce         Boolean             @default(true)
  imagens                  ProdutoImagem[]
  aplicacoes               ProdutoAplicacao[]
  fiscal                   ProdutoFiscal?
  fornecedores             ProdutoFornecedor[]
  lotes                    EstoqueLote[]
  series                   EstoqueSerie[]
  saldosEstoque            EstoqueSaldo[]
  movimentosEstoque        EstoqueMovimento[]
  reservasEstoque          EstoqueReserva[]
  entradasFiscaisItens     EntradaFiscalItem[]
  itensPedidoVenda         PedidoVendaItem[]
  itensOrcamento           OrcamentoItem[]
  pecasServico             OrdemServicoPeca[]
  itensCompra              PedidoCompraItem[]
  itensPreco               TabelaPrecoItem[]
  criadoEm                 DateTime            @default(now())
  atualizadoEm             DateTime            @updatedAt

  @@unique([tenantId, empresaId, sku])
  @@index([tenantId, empresaId])
  @@index([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, gtin])
  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, categoriaId])
  @@index([tenantId, empresaId, marcaId])
}

model ProdutoImagem {
  id        String  @id @default(cuid())
  tenantId  String
  empresaId String
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  url       String
  textoAlt  String?
  ordem     Int     @default(0)

  @@index([tenantId, empresaId])
}

model ProdutoAplicacao {
  id          String  @id @default(cuid())
  tenantId    String
  empresaId   String
  produtoId   String
  produto     Produto @relation(fields: [produtoId], references: [id])
  marca       String?
  modelo      String?
  anoFaixa    String?
  observacoes String?

  @@index([tenantId, empresaId])
}

model ProdutoFiscal {
  id                    String   @id @default(cuid())
  tenantId              String
  empresaId             String
  produtoId             String   @unique
  regraTributariaId     String?
  produto               Produto  @relation(fields: [produtoId], references: [id])
  regraTributaria       RegraTributaria? @relation(fields: [regraTributariaId], references: [id])
  ncm                   String
  cest                  String?
  origem                String?
  exTipi                String?
  codigoBeneficioFiscal String?
  // ICMS - Regime Normal (CST 00–90)
  icmsCST               String?
  // ICMS - Simples Nacional (CSOSN 101–900)
  icmsCSOSN             String?
  // Modalidade de determinação da BC do ICMS: 0-Margem, 1-Pauta, 2-Preço Tabelado, 3-Preço Efetivo
  icmsModBC             Int?
  icmsAliquota          Decimal? @db.Decimal(8, 4)
  icmsReducaoBC         Decimal? @db.Decimal(8, 4)
  // ICMS-ST (Substituição Tributária) — CST 10, 30, 70, 90 / CSOSN 201, 202, 203, 900
  icmsSTModBC           Int?
  icmsSTMVA             Decimal? @db.Decimal(8, 4)
  icmsSTReducaoBC       Decimal? @db.Decimal(8, 4)
  icmsSTAliquota        Decimal? @db.Decimal(8, 4)
  // FCP — Fundo de Combate à Pobreza
  fcpAliquota           Decimal? @db.Decimal(8, 4)
  fcpSTAliquota         Decimal? @db.Decimal(8, 4)
  // IPI
  ipiCST                String?
  ipiCodEnq             String?
  ipiAliquota           Decimal? @db.Decimal(8, 4)
  // PIS
  pisCST                String?
  pisAliquota           Decimal? @db.Decimal(8, 4)
  // COFINS
  cofinsCST             String?
  cofinsAliquota        Decimal? @db.Decimal(8, 4)
  // ISS — Imposto sobre Serviços
  issAliquota           Decimal? @db.Decimal(8, 4)
  issItemListServico    String?
  // NF-e 4.0 — obrigatório para bebidas, cigarros, veículos e outros
  indicadorEscalaRelevante String?
  observacoes           String?
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@unique([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, cest])
  @@index([tenantId, empresaId, regraTributariaId])
}

model ProdutoFornecedor {
  id                  String     @id @default(cuid())
  tenantId            String
  empresaId           String
  produtoId           String
  fornecedorId        String
  produto             Produto    @relation(fields: [produtoId], references: [id])
  fornecedor          Fornecedor @relation(fields: [fornecedorId], references: [id])
  codigoFornecedor    String
  descricaoFornecedor String?
  gtinFornecedor      String?
  unidadeCompra       String     @default("UN")
  fatorConversao      Decimal    @default(1) @db.Decimal(14, 6)
  leadTimeDias        Int?
  compraMinima        Decimal?   @db.Decimal(14, 4)
  custoUltimaCompra   Decimal?   @db.Decimal(14, 4)
  principal           Boolean    @default(false)
  ativo               Boolean    @default(true)
  criadoEm            DateTime   @default(now())
  atualizadoEm        DateTime   @updatedAt

  @@unique([tenantId, empresaId, fornecedorId, codigoFornecedor])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, fornecedorId])
}

model Deposito {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  nome         String
  uf           String?
  ativo        Boolean            @default(true)
  lotes        EstoqueLote[]
  series       EstoqueSerie[]
  saldos       EstoqueSaldo[]
  movimentos   EstoqueMovimento[]
  reservas     EstoqueReserva[]
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model EstoqueSaldo {
  id           String       @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  loteId       String?
  controleKey  String       @default("SEM_CONTROLE")
  produto      Produto      @relation(fields: [produtoId], references: [id])
  deposito     Deposito     @relation(fields: [depositoId], references: [id])
  lote         EstoqueLote? @relation(fields: [loteId], references: [id])
  quantidade   Decimal      @default(0) @db.Decimal(14, 4)
  reservado    Decimal      @default(0) @db.Decimal(14, 4)
  minimo       Decimal      @default(0) @db.Decimal(14, 4)
  maximo       Decimal      @default(0) @db.Decimal(14, 4)
  atualizadoEm DateTime     @updatedAt

  @@unique([tenantId, empresaId, produtoId, depositoId, controleKey])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, depositoId])
}

model EstoqueMovimento {
  id             String               @id @default(cuid())
  tenantId       String
  empresaId      String
  produtoId      String
  depositoId     String
  loteId         String?
  serieId        String?
  produto        Produto              @relation(fields: [produtoId], references: [id])
  deposito       Deposito             @relation(fields: [depositoId], references: [id])
  lote           EstoqueLote?         @relation(fields: [loteId], references: [id])
  serie          EstoqueSerie?        @relation(fields: [serieId], references: [id])
  tipo           TipoMovimentoEstoque
  quantidade     Decimal              @db.Decimal(14, 4)
  saldoAntes     Decimal?             @db.Decimal(14, 4)
  saldoDepois    Decimal?             @db.Decimal(14, 4)
  custoUnitario  Decimal?             @db.Decimal(14, 4)
  custoTotal     Decimal?             @db.Decimal(14, 4)
  documentoTipo  String?
  documentoId    String?
  idempotencyKey String?
  usuarioId      String?
  origem         String?
  origemId       String?
  observacoes    String?
  criadoEm       DateTime             @default(now())

  @@unique([tenantId, empresaId, idempotencyKey])
  @@index([tenantId, empresaId, produtoId, depositoId, criadoEm])
  @@index([tenantId, empresaId, documentoTipo, documentoId])
}

model EstoqueLote {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  produto      Produto            @relation(fields: [produtoId], references: [id])
  deposito     Deposito           @relation(fields: [depositoId], references: [id])
  numero       String
  fabricadoEm  DateTime?
  validadeEm   DateTime?
  saldos       EstoqueSaldo[]
  movimentos   EstoqueMovimento[]
  series       EstoqueSerie[]
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, produtoId, depositoId, numero])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, validadeEm])
}

model EstoqueSerie {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  loteId       String?
  produto      Produto            @relation(fields: [produtoId], references: [id])
  deposito     Deposito           @relation(fields: [depositoId], references: [id])
  lote         EstoqueLote?       @relation(fields: [loteId], references: [id])
  numeroSerie  String
  disponivel   Boolean            @default(true)
  movimentos   EstoqueMovimento[]
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, produtoId, numeroSerie])
  @@index([tenantId, empresaId, depositoId])
}

model EstoqueReserva {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  produto      Produto   @relation(fields: [produtoId], references: [id])
  deposito     Deposito  @relation(fields: [depositoId], references: [id])
  quantidade   Decimal   @db.Decimal(14, 4)
  origemTipo   String
  origemId     String
  expiraEm     DateTime?
  ativa        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([tenantId, empresaId, produtoId, depositoId])
  @@index([tenantId, empresaId, origemTipo, origemId])
}

