}

model ConfiguracaoFiscal {
  id                 String          @id @default(cuid())
  tenantId           String
  empresaId          String          @unique
  empresa            Empresa         @relation(fields: [empresaId], references: [id])
  provedor           ProvedorFiscal  @default(MANUAL)
  ambiente           AmbienteFiscal  @default(HOMOLOGACAO)
  regimeTributario   RegimeTributario @default(SIMPLES_NACIONAL)
  baseUrl            String?
  tokenCriptografado String?
  cscId              String?
  cscTokenCriptografado String?
  nfceIdCsc          String?
  nfceCscCriptografado String?
