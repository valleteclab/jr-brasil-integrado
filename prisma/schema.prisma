model Produto {
  id                       String                  @id @default(cuid())
  tenantId                 String
  empresaId                String
  empresa                  Empresa                 @relation(fields: [empresaId], references: [id])
  sku                      String
  nome                     String
  descricao                String?
  descricaoComercial       String?
  tipo                     TipoProduto             @default(PRODUTO)
  codigoOriginal           String?
  codigoFabricante         String?
  gtin                     String?
  categoriaId              String
  marcaId                  String?
  categoria                ProdutoCategoria        @relation(fields: [categoriaId], references: [id])
  marca                    ProdutoMarca?           @relation(fields: [marcaId], references: [id])
  unidade                  String                  @default("UN")
  unidadeCompra            String                  @default("UN")
  fatorConversaoCompra     Decimal                 @default(1) @db.Decimal(14, 6)
  pesoKg                   Decimal?                @db.Decimal(10, 3)
  pesoBrutoKg              Decimal?                @db.Decimal(10, 3)
  alturaCm                 Decimal?                @db.Decimal(10, 3)
  larguraCm                Decimal?                @db.Decimal(10, 3)
  comprimentoCm            Decimal?                @db.Decimal(10, 3)
  ncm                      String?
  cest                     String?
  cfop                     String?
  origem                   String?
  precoCusto               Decimal                 @default(0) @db.Decimal(14, 2)
  ultimoCusto              Decimal                 @default(0) @db.Decimal(14, 2)
  custoMedio               Decimal                 @default(0) @db.Decimal(14, 4)
  precoVenda               Decimal                 @default(0) @db.Decimal(14, 2)
  precoMinimo              Decimal                 @default(0) @db.Decimal(14, 2)
  margemAlvoPercentual     Decimal?                @db.Decimal(8, 4)
  quantidadeMinima         Int                     @default(1)
  controlaLote             Boolean                 @default(false)
  controlaSerie            Boolean                 @default(false)
  controlaValidade         Boolean                 @default(false)
  permiteEstoqueNegativo   Boolean                 @default(false)
  permiteVendaSobEncomenda Boolean                 @default(false)
  ativoCompra              Boolean                 @default(true)
  ativoVenda               Boolean                 @default(true)
  ativo                    Boolean                 @default(true)
  visivelEcommerce         Boolean                 @default(true)
  imagens                  ProdutoImagem[]
  aplicacoes               ProdutoAplicacao[]
  fiscal                   ProdutoFiscal?
  fornecedores             ProdutoFornecedor[]
  lotes                    EstoqueLote[]
  series                   EstoqueSerie[]
  saldosEstoque            EstoqueSaldo[]
  movimentosEstoque        EstoqueMovimento[]
  reservasEstoque          EstoqueReserva[]
  entradasFiscaisItens     EntradaFiscalItem[]
  itensPedidoVenda         PedidoVendaItem[]
  itensOrcamento           OrcamentoItem[]
  pecasServico             OrdemServicoPeca[]
  itensCompra              PedidoCompraItem[]
  itensPreco               TabelaPrecoItem[]
  itensNotaFiscal          NotaFiscalItem[]
  itensInventario          InventarioItem[]
  itensRetirada            ExpedicaoRetiradaItem[]
  criadoEm                 DateTime                @default(now())
  atualizadoEm             DateTime                @updatedAt

  @@unique([tenantId, empresaId, sku])
  @@index([tenantId, empresaId])
  @@index([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, gtin])
  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, categoriaId])
  @@index([tenantId, empresaId, marcaId])
}

