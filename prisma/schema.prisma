/// Certificado digital A1 (.pfx) da empresa, criptografado. Necessário para o provedor NACIONAL
/// (assina o DPS da NFS-e e faz o mTLS na SEFIN). Guardado só criptografado; decriptado em memória.
model CertificadoDigital {
  id                 String   @id @default(cuid())
  tenantId           String
  empresaId          String   @unique
  empresa            Empresa  @relation(fields: [empresaId], references: [id])
  /// .pfx criptografado (encryptSecret) — base64 dos bytes do certificado.
  pfxCriptografado   String
  /// Senha do .pfx criptografada (encryptSecret).
  senhaCriptografada String
  titularCnpj        String?
  validade           DateTime?
  arquivoNome        String?
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model ConfiguracaoFiscal {
  id                       String           @id @default(cuid())
  tenantId                 String
  empresaId                String           @unique
  empresa                  Empresa          @relation(fields: [empresaId], references: [id])
  provedor                 ProvedorFiscal   @default(MANUAL)
  /// Provedor da NFS-e (serviços). Quando null, usa `provedor`. Permite NF-e/NFC-e no ACBr e
  /// NFS-e no NACIONAL (direto). Roteamento por modelo na emissão.
  provedorServicos         ProvedorFiscal?
  ambiente                 AmbienteFiscal   @default(HOMOLOGACAO)
  regimeTributario         RegimeTributario @default(SIMPLES_NACIONAL)
  baseUrl                  String?
  tokenCriptografado       String?
  cscId                    String?
  cscTokenCriptografado    String?
  // CSC da NFC-e por AMBIENTE (códigos distintos). Os campos sem sufixo são de HOMOLOGAÇÃO; os
  // *Producao, de PRODUÇÃO. getFiscalRuntimeConfig entrega o par do ambiente ativo da empresa.
  nfceIdCsc                String?
  nfceCscCriptografado     String?
  nfceIdCscProducao        String?
  nfceCscProducaoCriptografado String?
  serieNfe                 String           @default("1")
  serieNfce                String           @default("1")
  serieNfse                String           @default("1")
  emitirNfe                Boolean          @default(true)
  emitirNfce               Boolean          @default(false)
  emitirNfse               Boolean          @default(false)
  codigoMunicipioIbge      String?
  codigoServicoLc116Padrao String?
  codigoNbsPadrao          String?
  // Spedy: COMPLETO envia tributacao calculada pelo ERP (/product-invoices); SIMPLIFICADO usa /orders (tributacao no backoffice da Spedy).
  spedyModoEmissao         String?          @default("COMPLETO")
  regimeEspecialTributacao String?
  incentivadorCultural     Boolean          @default(false)
  certificadoInfo          String?
  certificadoValidade      DateTime?
  logotipoInfo             String?
  // Conteudo da logo (data URL base64 PNG/JPEG) para o DANFE proprio (SEFAZ direto); o ACBr guarda
  // a sua copia no backoffice deles. logotipoInfo mantem so o nome do arquivo (exibicao).
  logotipoConteudo         String?
  // Última vez que a distribuição de NF-e recebidas (NFeDistribuicaoDFe) foi sincronizada — cron ou manual.
  distribuicaoSyncEm       DateTime?
  // Quando true, o próximo ciclo do cron re-baixa o histórico do NSU 0 (re-sync) e zera o flag. Corrige
  // resumos antigos sem data de emissão (ex.: vindos do ACBr). Auto-retry enquanto houver throttling.
  distribuicaoReprocessar  Boolean?
  // Distribuição de NFS-e (ADN): último NSU já sincronizado + quando.
  nfseDistNsu              String?
  nfseDistSyncEm           DateTime?
  nfseAmbienteNacional     Boolean?
  ativo                    Boolean          @default(false)
  testadoEm                DateTime?
  ultimoErro               String?
  observacoes              String?
  criadoEm                 DateTime         @default(now())
  atualizadoEm             DateTime         @updatedAt

  @@index([tenantId, empresaId])
}

model SequenciaFiscal {
  id           String         @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa        @relation(fields: [empresaId], references: [id])
  modelo       ModeloFiscal
  serie        String
  // Numeração SEPARADA por ambiente: testes em HOMOLOGAÇÃO não consomem a faixa de PRODUÇÃO.
  ambiente     AmbienteFiscal @default(HOMOLOGACAO)
  ultimoNumero Int            @default(0)
  ativo        Boolean        @default(true)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  @@unique([tenantId, empresaId, modelo, serie, ambiente])
  @@index([tenantId, empresaId])
}

// ---------------------------------------------------------------------------
// SPED Fiscal (EFD ICMS/IPI) — módulo liberado por tenant pelo dono do SaaS
// ---------------------------------------------------------------------------

// Status do arquivo gerado: GERADO (pronto para download) ou ENVIADO_CONTADOR (marcado
// pelo usuário após enviar o .txt ao contador, que valida no PVA e transmite).
enum StatusSpedArquivo {
  GERADO
  ENVIADO_CONTADOR
}

// Configuração da escrituração por empresa: perfil do arquivo (0000.IND_PERFIL), atividade
// (0000.IND_ATIV), dados do contador (registro 0100) e parâmetros do E116 (código de receita
// e dia de vencimento do ICMS, que variam por UF).
model SpedConfiguracao {
  id                          String   @id @default(cuid())
  tenantId                    String
  empresaId                   String   @unique
  empresa                     Empresa  @relation(fields: [empresaId], references: [id])
  // IND_PERFIL do registro 0000: A, B ou C (definido pela SEFAZ da UF da empresa).
  perfilArquivo               String   @default("B")
  // IND_ATIV do registro 0000: 0 = industrial/equiparado a industrial, 1 = outros.
  indAtividade                String   @default("1")
  // Contador responsável (registro 0100 — obrigatório no arquivo).
  contadorNome                String?
  contadorCpf                 String?
  contadorCrc                 String?
  contadorCnpj                String?
  contadorCep                 String?
  contadorEndereco            String?
  contadorNumero              String?
  contadorComplemento         String?
  contadorBairro              String?
  contadorTelefone            String?
  contadorEmail               String?
  contadorCodigoMunicipioIbge String?
  // E116 (obrigação do ICMS a recolher): código de receita estadual e dia de vencimento.
  codigoReceitaIcms           String?
  diaVencimentoIcms           Int      @default(10)
  // CIAP (bloco G): código de ajuste E111 da tabela 5.1.1 da UF para a apropriação mensal
  // do crédito do ativo (ex.: estrutura UF02xxxx). Sem ele, o bloco G é gerado e o crédito
  // fica de fora da apuração, com aviso.
  codAjusteCreditoCiap        String?
  // Bloco K restrito ao saldo de estoque (K010 modo 2 + K100 + K200 a partir do EstoqueSaldo).
  gerarBlocoK                 Boolean  @default(false)
  // ICMS Antecipação Parcial (compras interestaduais p/ revenda — ex.: BA, Lei 7.014/96).
  // Quando ativa, o gerador calcula (alíq. interna − interestadual) × base e escritura:
  // E111 débito especial + E111 crédito (regime conta-corrente) + E116 da guia.
  antecipacaoParcialAtiva     Boolean  @default(false)
  codAjusteDebitoAntecipacao  String? // BA: BA050004
  codAjusteCreditoAntecipacao String? // BA: BA020002
  codigoReceitaAntecipacao    String? // BA: 2175 (DAE)
  diaVencimentoAntecipacao    Int      @default(25)
  criadoEm                    DateTime @default(now())
  atualizadoEm                DateTime @updatedAt

  @@index([tenantId, empresaId])
}

// Bem do ativo imobilizado controlado no CIAP (bloco G da EFD): o crédito de ICMS do ativo
// é apropriado em 48 parcelas mensais × fator de saídas tributadas (LC 87/96, art. 20, §5º).
// Criado automaticamente ao processar entrada com finalidade IMOBILIZADO, ou manualmente.
model CiapBem {
  id                  String    @id @default(cuid())
  tenantId            String
  empresaId           String
  empresa             Empresa   @relation(fields: [empresaId], references: [id])
  // COD_IND_BEM (0300/G125) — código único do bem na empresa.
  codigo              String
  descricao           String
  // IDENT_MERC do 0300: 1 = bem, 2 = componente.
  identMerc           String    @default("1")
  // 0305: função do bem no estabelecimento e vida útil em anos.
  funcao              String?
  vidaUtilAnos        Int       @default(5)
  // Créditos de ICMS passíveis de apropriação (G125): operação própria, ST, frete e DIFAL.
  valorIcmsOp         Decimal   @default(0) @db.Decimal(14, 2)
  valorIcmsSt         Decimal   @default(0) @db.Decimal(14, 2)
  valorIcmsFrete      Decimal   @default(0) @db.Decimal(14, 2)
  valorIcmsDif        Decimal   @default(0) @db.Decimal(14, 2)
  parcelasTotal       Int       @default(48)
  // Início da apropriação (mês da imobilização — TIPO_MOV IM no G125).
  imobilizadoEm       DateTime
  // Baixa/alienação encerra a apropriação (ajuste fino do G125 BA com o contador).
  baixadoEm           DateTime?
  // Documento fiscal de aquisição (G130) e item (G140).
  fornecedorDocumento String?
  fornecedorNome      String?
  docModelo           String?
  docSerie            String?
  docNumero           String?
  chaveAcesso         String?
  docEmitidaEm        DateTime?
  itemCodigo          String?
  itemQuantidade      Decimal?  @db.Decimal(14, 4)
  itemUnidade         String?
  entradaFiscalItemId String?
  observacoes         String?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@unique([tenantId, empresaId, codigo])
  @@index([tenantId, empresaId, imobilizadoEm])
}

// Arquivo EFD ICMS/IPI gerado para uma competência (ano/mês). Guarda o .txt completo,
// o resumo estruturado da apuração (exibido na tela) e os avisos da geração. Uma
// competência tem no máximo um arquivo por empresa — regerar substitui o anterior.
model SpedArquivo {
  id                  String            @id @default(cuid())
  tenantId            String
  empresaId           String
  empresa             Empresa           @relation(fields: [empresaId], references: [id])
  ano                 Int
  mes                 Int
  // COD_VER do registro 0000 (ex.: "020" para 2026). Versionado para suportar leiautes
  // futuros, incluindo os registros de IBS/CBS da reforma tributária quando publicados.
  versaoLeiaute       String
  // COD_FIN do registro 0000: ORIGINAL (0) ou RETIFICADORA (1).
  finalidade          String            @default("ORIGINAL")
  perfilArquivo       String            @default("B")
  status              StatusSpedArquivo @default(GERADO)
  conteudo            String
  totalLinhas         Int
  // Resumo estruturado: apuração ICMS/ICMS-ST/IPI/PIS/COFINS, totais por CFOP,
  // contagem de registros por tipo e documentos considerados.
  resumo              Json
  // Avisos e pendências detectadas na geração (cadastros incompletos, CST ausente etc.).
  avisos              Json
  saldoCredorAnterior Decimal           @default(0) @db.Decimal(14, 2)
  geradoPor           String?
  enviadoContadorEm   DateTime?
  // Análise da apuração feita pela IA (OpenRouter): parecer, inconsistências e checklist.
  // A IA NUNCA gera o arquivo — só audita o resumo produzido pelo gerador determinístico.
  analiseIa           Json?
  analiseIaEm         DateTime?
  criadoEm            DateTime          @default(now())
  atualizadoEm        DateTime          @updatedAt

  @@unique([tenantId, empresaId, ano, mes])
  @@index([tenantId, empresaId, status])
}

// XML avulso importado só para o SPED: notas emitidas fora do ERP (outro emissor) ou
// recebidas sem passar pelo fluxo de entradas. Entram na geração do arquivo junto com as
// notas do banco, com deduplicação por chave de acesso (a nota do ERP prevalece).
model SpedXmlDocumento {
  id                    String    @id @default(cuid())
  tenantId              String
  empresaId             String
  empresa               Empresa   @relation(fields: [empresaId], references: [id])
  chaveAcesso           String
  // SAIDA quando o emitente do XML é a própria empresa; ENTRADA quando é terceiro.
  tipo                  String
  cancelada             Boolean   @default(false)
  modelo                String?
  numero                String?
  serie                 String?
  emitidaEm             DateTime?
  competenciaAno        Int
  competenciaMes        Int
  emitenteDocumento     String?
  emitenteNome          String?
  destinatarioDocumento String?
  destinatarioNome      String?
  valorTotal            Decimal   @default(0) @db.Decimal(14, 2)
  xml                   String
  // Finalidade de entrada definida MANUALMENTE pelo usuário por item ({"1":"REVENDA",...}).
  // Prevalece sobre regra De/Para e heurística na geração do SPED (créditos corretos).
  finalidadesItens      Json?
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, competenciaAno, competenciaMes])
}

// Conta financeira (carteira) de onde o dinheiro sai/entra: caixa, conta bancária ou cartão.
// O campo `tipo` categoriza (CAIXA, CORRENTE, POUPANCA, CARTAO). Banco/agência/conta só se aplicam
// a contas bancárias; cartões usam nome + tipo CARTAO.
model ContaBancaria {
  id              String                @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa               @relation(fields: [empresaId], references: [id])
  nome            String
  banco           String?
  agencia         String?
  conta           String?
  tipo            String                @default("CORRENTE")
  // Chave PIX recebedora desta conta (para escolher no recebimento). tipoChavePix: CPF|CNPJ|EMAIL|TELEFONE|ALEATORIA.
  chavePix        String?
  tipoChavePix    String?
  saldoInicial    Decimal               @default(0) @db.Decimal(14, 2)
  saldoAtual      Decimal               @default(0) @db.Decimal(14, 2)
  ativo           Boolean               @default(true)
  movimentos      MovimentoFinanceiro[]
  contasPagar     ContaPagar[]
  contasReceber   ContaReceber[]
  formasPagamento FormaPagamento[]
  antecipacoes    AntecipacaoRecebivel[]
  // ── Cobrança Sicoob (emissão de boleto pela API oficial) ──
  // Credenciamento por conta: client_id (obtido no Sicoob Desenvolvedores), número do cliente
  // (código do beneficiário/cooperado) e conta corrente de cobrança. O mTLS de produção usa o
  // A1 e-CNPJ da empresa (CertificadoDigital, o mesmo do fiscal). Sandbox usa token do portal.
  sicoobClientId        String?
  sicoobNumeroCliente   Int?
  sicoobContaCorrente   String?
  /// Modalidade de cobrança (1 = simples com registro).
  sicoobModalidade      Int      @default(1)
  /// Ambiente da API: true = sandbox (token do portal, sem mTLS).
  sicoobSandbox         Boolean  @default(false)
  /// Token do sandbox (criptografado com encryptSecret).
  sicoobSandboxToken    String?
  /// Webhook de liquidação da cobrança (baixa em tempo real): id devolvido pelo Sicoob no cadastro
  /// e segredo aleatório embutido na URL pública (autentica a chamada do banco sem depender do corpo).
  sicoobWebhookId       Int?
  sicoobWebhookSecret   String?
  boletos               BoletoCobranca[]
  pixCobrancas          PixCobranca[]
  emprestimos           Emprestimo[]
  despesasRecorrentes   DespesaRecorrente[]
  criadoEm        DateTime              @default(now())
  atualizadoEm    DateTime              @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

/// Boleto REGISTRADO na API de Cobrança do Sicoob para uma ContaReceber. Guarda os dados de
/// cobrança (nosso número, linha digitável, código de barras, PDF) e o status do ciclo de vida.
model BoletoCobranca {
  id              String        @id @default(cuid())
  tenantId        String
  empresaId       String
  contaReceberId  String        @unique
  contaReceber    ContaReceber  @relation(fields: [contaReceberId], references: [id])
  contaBancariaId String
  contaBancaria   ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  /// EMITIDO → REGISTRADO (confirmado no banco) → LIQUIDADO | BAIXADO | ERRO
  status          String        @default("EMITIDO")
  nossoNumero     String?
  seuNumero       String?
  linhaDigitavel  String?
  codigoBarras    String?
  valor           Decimal       @db.Decimal(14, 2)
  vencimento      DateTime
  /// PDF do boleto em base64 (retornado no registro), servido pela rota de download.
  pdfBase64       String?
  ultimoErro      String?
  payload         Json?
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, nossoNumero])
}

/// GUIA DE RECOLHIMENTO ESTADUAL gerada pela emissão (Conv. ICMS 142/2018, cl. 18ª): remetente
/// sem inscrição na UF de destino recolhe o ICMS-ST retido POR OPERAÇÃO via GNRE ANTES da saída
/// (a guia acompanha o transporte). v1: o ERP calcula, registra e controla (pendente/paga); a
/// guia em si é emitida no portal GNRE Online — webservice é fase futura.
model GuiaRecolhimento {
  id           String         @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa        @relation(fields: [empresaId], references: [id])
  ambiente     AmbienteFiscal @default(HOMOLOGACAO)
  notaFiscalId String
  notaFiscal   NotaFiscal     @relation(fields: [notaFiscalId], references: [id])
  /// GNRE_ICMS_ST | GNRE_DIFAL
  tipo         String         @default("GNRE_ICMS_ST")
  ufFavorecida String
  valor        Decimal        @db.Decimal(14, 2)
  /// PENDENTE | PAGA | CANCELADA
  status       String         @default("PENDENTE")
  numeroGuia   String?
  pagoEm       DateTime?
  observacoes  String?
  /// Código de PRODUTO da GNRE exigido por algumas UFs (tabela da UF via GnreConfigUF).
  produtoGnre    String?
  /// Código de RECEITA da GNRE da UF favorecida (default 100048; PR usa 100099 p/ operação).
  receitaGnre    String?
  /// Emissão pelo webservice GNRE: recibo do lote, linha digitável, código de barras e PDF.
  reciboLote     String?
  linhaDigitavel String?
  codigoBarras   String?
  pdfBase64      String?
  situacaoWs     String?
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  @@unique([notaFiscalId, tipo])
  @@index([tenantId, empresaId, status])
}

/// Cobrança PIX dinâmica (QR Code) criada na API Pix do Sicoob (BACEN cob). Vinculada à venda
/// e/ou à conta a receber quando usada para receber um título; a liquidação chega por
/// consulta/cron/webhook e marca CONCLUIDA.
model PixCobranca {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  ambiente        AmbienteFiscal @default(HOMOLOGACAO)
  contaBancariaId String
  contaBancaria   ContaBancaria  @relation(fields: [contaBancariaId], references: [id])
  contaReceberId  String?        @unique
  contaReceber    ContaReceber?  @relation(fields: [contaReceberId], references: [id])
  pedidoVendaId   String?
  /// txid BACEN (26-35 chars alfanuméricos), gerado pelo ERP.
  txid            String         @unique
  /// ATIVA → CONCLUIDA (paga) | REMOVIDA (expirada/cancelada) | ERRO
  status          String         @default("ATIVA")
  valor           Decimal        @db.Decimal(14, 2)
  chave           String
  /// Copia-e-cola (BR Code) para render do QR na tela.
  brcode          String?
  descricao       String?
  expiracaoSeg    Int            @default(3600)
  /// endToEndId do pagamento recebido (conciliação).
  e2eid           String?
  pagoEm          DateTime?
  ultimoErro      String?
  payload         Json?
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, pedidoVendaId])
}

// Forma de pagamento cadastrável (como se paga): Dinheiro, Pix, Cartão de crédito/débito,
// Boleto, Transferência, Cheque. Pode apontar para uma conta financeira (ContaBancaria) padrão,
// usada para relatórios e, futuramente, para a liquidação financeira automática.
model FormaPagamento {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  nome            String
  tipo            String         @default("OUTRO")
  contaBancariaId String?
  contaBancaria   ContaBancaria? @relation(fields: [contaBancariaId], references: [id])
  ativo           Boolean        @default(true)
  ordem           Int            @default(0)
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, ativo])
}

model MovimentoFinanceiro {
  id              String                  @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa                 @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando o movimento foi lançado. (Saldo da conta bancária é global.)
  ambiente        AmbienteFiscal          @default(HOMOLOGACAO)
  contaBancariaId String?
  contaBancaria   ContaBancaria?          @relation(fields: [contaBancariaId], references: [id])
  contaPagarId    String?
  contaPagar      ContaPagar?             @relation(fields: [contaPagarId], references: [id])
  contaReceberId  String?
  contaReceber    ContaReceber?           @relation(fields: [contaReceberId], references: [id])
  tipo            TipoMovimentoFinanceiro
  origem          String
  descricao       String
  valor           Decimal                 @db.Decimal(14, 2)
  formaPagamento  String?
  // Detalhe do pagamento (ex.: contas a pagar quitadas no cartão): qual maquininha/cartão,
  // bandeira e nº de parcelas (1 = à vista). Reusa o cadastro de MaquinaCartao.
  maquinaCartaoId String?
  bandeira        String?
  parcelas        Int?
  saldoAnterior   Decimal?                @db.Decimal(14, 2)
  saldoPosterior  Decimal?                @db.Decimal(14, 2)
  dataMovimento   DateTime                @default(now())
  usuarioId       String?
  criadoEm        DateTime                @default(now())

  @@index([tenantId, empresaId, dataMovimento])
  @@index([tenantId, empresaId, contaBancariaId])
  @@index([tenantId, empresaId, origem])
}

model Inventario {
  id           String           @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa          @relation(fields: [empresaId], references: [id])
  depositoId   String
  deposito     Deposito         @relation(fields: [depositoId], references: [id])
  numero       String
  descricao    String?
  status       StatusInventario @default(ABERTO)
  iniciadoEm   DateTime?
  finalizadoEm DateTime?
  observacoes  String?
  itens        InventarioItem[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId, status])
}

model InventarioItem {
  id            String     @id @default(cuid())
  tenantId      String
  empresaId     String
  inventarioId  String
  produtoId     String
  inventario    Inventario @relation(fields: [inventarioId], references: [id])
  produto       Produto    @relation(fields: [produtoId], references: [id])
  saldoSistema  Decimal    @db.Decimal(14, 4)
  saldoContado  Decimal?   @db.Decimal(14, 4)
  custoUnitario Decimal    @default(0) @db.Decimal(14, 4)
  contado       Boolean    @default(false)
  ajustado      Boolean    @default(false)

  @@unique([tenantId, empresaId, inventarioId, produtoId])
  @@index([tenantId, empresaId, inventarioId])
}

model Caixa {
  id                   String           @id @default(cuid())
  tenantId             String
  empresaId            String
  // Ambiente fiscal vigente quando o caixa foi aberto.
  ambiente             AmbienteFiscal   @default(HOMOLOGACAO)
  operador             String
  status               StatusCaixa      @default(ABERTO)
  saldoInicial         Decimal          @default(0) @db.Decimal(14, 2)
  saldoFinalInformado  Decimal?         @db.Decimal(14, 2)
  observacaoAbertura   String?
  observacaoFechamento String?
  abertoEm             DateTime         @default(now())
  fechadoEm            DateTime?
  movimentos           CaixaMovimento[]
  criadoEm             DateTime         @default(now())
  atualizadoEm         DateTime         @updatedAt

  @@index([tenantId, empresaId, status])
}

model CaixaMovimento {
  id             String             @id @default(cuid())
  tenantId       String
  empresaId      String
  // Ambiente fiscal vigente quando o movimento de caixa foi lançado.
  ambiente       AmbienteFiscal     @default(HOMOLOGACAO)
  caixaId        String
  caixa          Caixa              @relation(fields: [caixaId], references: [id])
  tipo           TipoCaixaMovimento
  formaPagamento String?
  valor          Decimal            @db.Decimal(14, 2)
  pedidoVendaId  String?
  pedidoVenda    PedidoVenda?       @relation(fields: [pedidoVendaId], references: [id])
  descricao      String?
  criadoEm       DateTime           @default(now())

  @@index([tenantId, empresaId, caixaId])
}

// Recibo de retirada na expedição: o caixa emite o recibo (código curto), o cliente
// apresenta no balcão de expedição, o conferente valida o código e confirma a entrega.
model ExpedicaoRetirada {
  id            String                  @id @default(cuid())
  tenantId      String
  empresaId     String
  empresa       Empresa                 @relation(fields: [empresaId], references: [id])
  // Código curto impresso no recibo (sem caracteres ambíguos), único por empresa.
  codigo        String
  pedidoVendaId String
  pedidoVenda   PedidoVenda             @relation(fields: [pedidoVendaId], references: [id])
  status        StatusRetirada          @default(PENDENTE)
  // Última entrega registrada (o histórico completo fica em observacoes + auditoria).
  entreguePor   String?
  entregueEm    DateTime?
  observacoes   String?
  itens         ExpedicaoRetiradaItem[]
  criadoEm      DateTime                @default(now())
  atualizadoEm  DateTime                @updatedAt

  @@unique([tenantId, empresaId, codigo])
  @@index([tenantId, empresaId, status])
}

// Saldo de retirada por produto: permite entrega parcial (entregue acumula até quantidade).
model ExpedicaoRetiradaItem {
  id         String            @id @default(cuid())
  tenantId   String
  empresaId  String
  retiradaId String
  retirada   ExpedicaoRetirada @relation(fields: [retiradaId], references: [id])
  produtoId  String
  produto    Produto           @relation(fields: [produtoId], references: [id])
  quantidade Decimal           @db.Decimal(14, 4)
  entregue   Decimal           @default(0) @db.Decimal(14, 4)

  @@unique([retiradaId, produtoId])
  @@index([tenantId, empresaId])
}

model Vendedor {
  id                 String          @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa         @relation(fields: [empresaId], references: [id])
  nome               String
  email              String?
  percentualComissao Decimal         @default(0) @db.Decimal(5, 2)
  ativo              Boolean         @default(true)
  pedidosVenda       PedidoVenda[]
  orcamentos         Orcamento[]
  comissoes          ComissaoVenda[]
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, ativo])
}

// Comissão apurada na confirmação da venda (1:1 com o pedido). Cancelamento da venda
// cancela a comissão; devolução abate proporcionalmente o valor a pagar.
model ComissaoVenda {
  id            String         @id @default(cuid())
  tenantId      String
  empresaId     String
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  vendedorId    String
  vendedor      Vendedor       @relation(fields: [vendedorId], references: [id])
  pedidoVendaId String         @unique
  pedidoVenda   PedidoVenda    @relation(fields: [pedidoVendaId], references: [id])
  base          Decimal        @db.Decimal(14, 2)
  percentual    Decimal        @db.Decimal(5, 2)
  valor         Decimal        @db.Decimal(14, 2)
  status        StatusComissao @default(A_PAGAR)
  pagoEm        DateTime?
  observacoes   String?
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, vendedorId, status])
}

model PagamentoVenda {
  id              String      @id @default(cuid())
  tenantId        String
  empresaId       String
  pedidoVendaId   String
  pedidoVenda     PedidoVenda @relation(fields: [pedidoVendaId], references: [id])
  forma           String
  valor           Decimal     @db.Decimal(14, 2)
  troco           Decimal     @default(0) @db.Decimal(14, 2)
  // Detalhe do recebimento: destino e dados da transação.
  contaBancariaId String? // conta/chave PIX (ou transferência) que recebeu
  maquinaCartaoId String? // máquina de cartão usada
  nsu             String? // NSU/identificador da transação do cartão
  bandeira        String? // VISA, MASTERCARD, ELO...
  parcelas        Int? // nº de parcelas (cartão crédito)
  autorizacao     String? // código de autorização
  criadoEm        DateTime    @default(now())

  @@index([tenantId, empresaId, pedidoVendaId])
}

/// Máquina de cartão (maquininha) da empresa. Define a adquirente, a conta de liquidação e as
/// taxas/prazos usados para gerar o recebível (conta a receber da adquirente) no recebimento.
model MaquinaCartao {
  id                   String   @id @default(cuid())
  tenantId             String
  empresaId            String
  empresa              Empresa  @relation(fields: [empresaId], references: [id])
  nome                 String
  adquirente           String?
  contaBancariaId      String? // conta onde os recebíveis liquidam
  taxaDebito           Decimal  @default(0) @db.Decimal(6, 3)
  taxaCredito          Decimal  @default(0) @db.Decimal(6, 3)
  taxaCreditoParcelado Decimal  @default(0) @db.Decimal(6, 3)
  prazoDebitoDias      Int      @default(1)
  prazoCreditoDias     Int      @default(30)
  ativo                Boolean  @default(true)
  criadoEm             DateTime @default(now())
  atualizadoEm         DateTime @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model ConversaAgente {
  id           String           @id @default(cuid())
  tenantId     String
  empresaId    String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  empresa      Empresa          @relation(fields: [empresaId], references: [id])
  usuarioId    String?
  role         AgentRole
  titulo       String?
  canal        String           @default("WEB")
  telefone     String?
  mensagens    MensagemAgente[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  @@index([tenantId, empresaId])
}

model MensagemAgente {
  id          String         @id @default(cuid())
  tenantId    String
  empresaId   String
  conversaId  String
  conversa    ConversaAgente @relation(fields: [conversaId], references: [id])
  papel       MensagemPapel
  conteudo    String         @db.Text
  toolName    String?
  toolPayload Json?
  draftTipo   String?
  draftId     String?
  criadoEm    DateTime       @default(now())

  @@index([tenantId, empresaId, conversaId])
}

model ChaveApiAgente {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  nome         String
  role         AgentRole @default(GESTOR)
  hashChave    String    @unique
  chaveFinal   String
  ativo        Boolean   @default(true)
  ultimoUsoEm  DateTime?
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@index([tenantId, empresaId])
}

model AgenteTelefone {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  telefone     String
  nome         String?
  role         AgentRole @default(VENDEDOR)
  clienteId    String?
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@unique([telefone])
  @@index([tenantId, empresaId])
}

model ConfiguracaoWhatsapp {
  id                String           @id @default(cuid())
  tenantId          String
  empresaId         String           @unique
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  empresa           Empresa          @relation(fields: [empresaId], references: [id])
  provedor          ProvedorWhatsapp @default(ZAPI)
  ativo             Boolean          @default(false)
  instanceId        String?
  tokenCripto       String?
  clientTokenCripto String?
  webhookSecret     String?
  atenderClientes   Boolean          @default(true)
  criadoEm          DateTime         @default(now())
  atualizadoEm      DateTime         @updatedAt

  @@index([tenantId, empresaId])
}

// ─── Controle de gastos (despesas operacionais por cupom) ─────────────────────

enum GastoOrigem {
  PWA
  WHATSAPP
  MANUAL
}

enum GastoStatus {
  PENDENTE
  CONFIRMADO
}

/// Despesa operacional registrada a partir de foto de cupom (IA) ou manual. Controle próprio;
/// quando o usuário "lança no financeiro", gera uma ContaPagar quitada (contaPagarId).
model Gasto {
  id                String      @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa     @relation(fields: [empresaId], references: [id])
  estabelecimento   String
  documento         String?
  categoria         String
  data              DateTime
  valorTotal        Decimal     @db.Decimal(14, 2)
  formaPagamento    String?
  origem            GastoOrigem @default(MANUAL)
  status            GastoStatus @default(PENDENTE)
  imagemCupom       String?     @db.Text
  iaConfianca       Int?
  iaBruto           Json?
  contaPagarId      String?
  lancadoFinanceiro Boolean     @default(false)
  observacoes       String?
  criadoPor         String?
  itens             GastoItem[]
  criadoEm          DateTime    @default(now())
  atualizadoEm      DateTime    @updatedAt

  @@index([tenantId, empresaId, data])
  @@index([tenantId, empresaId, categoria])
}

model GastoItem {
  id         String   @id @default(cuid())
  tenantId   String
  empresaId  String
  gastoId    String
  gasto      Gasto    @relation(fields: [gastoId], references: [id])
  descricao  String
  quantidade Decimal? @db.Decimal(14, 3)
  valor      Decimal  @db.Decimal(14, 2)

  @@index([tenantId, empresaId, gastoId])
}
