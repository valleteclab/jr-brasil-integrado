// Sequência atômica de documentos operacionais (PV/ORC/OS/PC/INV) por empresa, espelhando
// a SequenciaFiscal. Incremento via UPDATE com lock de linha evita números duplicados quando
// dois PDVs/operadores criam documentos ao mesmo tempo.
model SequenciaDocumento {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  tipo         String
  ultimoNumero Int      @default(0)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tenantId, empresaId, tipo])
}

enum StatusNotaFiscal {
  RASCUNHO
  PROCESSANDO
  AUTORIZADA
  CANCELADA
  REJEITADA
  DENEGADA
  ERRO
  SUBSTITUIDA
}

enum ModeloFiscal {
  NFE
  NFCE
  NFSE
}

enum AmbienteFiscal {
  HOMOLOGACAO
  PRODUCAO
}

enum ProvedorFiscal {
  INTERNO
  FOCUS_NFE
  NFEIO
  PLUGNOTAS
  WEBMANIA
  SPEDY
  ACBR
  MANUAL
  // NFS-e direto no Sistema Nacional (SEFIN), assinado com o A1 da empresa (sem intermediário).
  NACIONAL
  // NF-e (modelo 55) direto nos web services da SEFAZ (SVRS/própria), assinada com o A1 da empresa.
  SEFAZ
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  SIMPLES_EXCESSO_SUBLIMITE
  LUCRO_PRESUMIDO
