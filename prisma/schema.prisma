  atualizadoEm       DateTime            @updatedAt

  @@unique([tenantId, empresaId, documento])
  @@index([tenantId, empresaId])
}

model PedidoCompra {
  id                String             @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa            @relation(fields: [empresaId], references: [id])
  numero            String
  fornecedorId      String
  fornecedor        Fornecedor         @relation(fields: [fornecedorId], references: [id])
  depositoId        String?
  status            StatusPedidoCompra @default(RASCUNHO)
  condicaoPagamento String?
  observacoes       String?
  previsaoEm        DateTime?
  subtotal          Decimal            @default(0) @db.Decimal(14, 2)
  frete             Decimal            @default(0) @db.Decimal(14, 2)
  total             Decimal            @default(0) @db.Decimal(14, 2)
  itens             PedidoCompraItem[]
  contasPagar       ContaPagar[]
  entradasFiscais   EntradaFiscal[]
  criadoEm          DateTime           @default(now())
  atualizadoEm      DateTime           @updatedAt

  @@unique([tenantId, empresaId, numero])
  @@index([tenantId, empresaId])
}

model PedidoCompraItem {
  id                 String       @id @default(cuid())
  tenantId           String
  empresaId          String
  pedidoCompraId     String
  produtoId          String
  pedidoCompra       PedidoCompra @relation(fields: [pedidoCompraId], references: [id])
  produto            Produto      @relation(fields: [produtoId], references: [id])
  quantidade         Int
  quantidadeRecebida Decimal      @default(0) @db.Decimal(14, 4)
  custoUnitario      Decimal      @db.Decimal(14, 2)
  total              Decimal      @db.Decimal(14, 2)
  // Conversão de embalagem: quantidade/custoUnitario são na unidade de COMPRA (ex.: CX/FD). Ao receber,
  // o estoque entra na unidade de venda (quantidade × fatorConversao) e o custo vira custoUnitario ÷ fator.
  // total/subtotal/conta a pagar permanecem na unidade de compra (= o que o fornecedor fatura).
  fatorConversao     Decimal      @default(1) @db.Decimal(14, 6)
  unidadeCompra      String?

  @@index([tenantId, empresaId])
}

model XmlImportacao {
  id                String                     @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa                    @relation(fields: [empresaId], references: [id])
  chaveAcesso       String?
  numero            String?
  serie             String?
  emitidaEm         DateTime?
  emitenteDocumento String?
  emitenteNome      String?
  status            StatusXmlImportacao        @default(RECEBIDO)
  checksum          String
  arquivoUrl        String?
  xmlOriginal       String?
  mensagemErro      String?
  entradasFiscais   EntradaFiscal[]
  distribuicoesNfe  DistribuicaoNfeDocumento[]
  criadoEm          DateTime                   @default(now())
  atualizadoEm      DateTime                   @updatedAt

  @@unique([tenantId, empresaId, checksum])
  @@unique([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, emitenteDocumento])
}

model EntradaFiscal {
  id                        String                     @id @default(cuid())
  tenantId                  String
  empresaId                 String
  empresa                   Empresa                    @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando a entrada foi registrada.
  ambiente                  AmbienteFiscal             @default(HOMOLOGACAO)
  fornecedorId              String?
  fornecedor                Fornecedor?                @relation(fields: [fornecedorId], references: [id])
  xmlImportacaoId           String?
  xmlImportacao             XmlImportacao?             @relation(fields: [xmlImportacaoId], references: [id])
  pedidoCompraId            String?
  pedidoCompra              PedidoCompra?              @relation(fields: [pedidoCompraId], references: [id])
  chaveAcesso               String?
  numero                    String?
  serie                     String?
  modelo                    String?
  cfopPrincipal             String?
  status                    StatusEntradaFiscal        @default(AGUARDANDO_CONFERENCIA)
  emitidaEm                 DateTime?
  recebidaEm                DateTime?
  totalProdutos             Decimal                    @default(0) @db.Decimal(14, 2)
  totalNota                 Decimal                    @default(0) @db.Decimal(14, 2)
  valorFrete                Decimal                    @default(0) @db.Decimal(14, 2)
  valorSeguro               Decimal                    @default(0) @db.Decimal(14, 2)
  valorDesconto             Decimal                    @default(0) @db.Decimal(14, 2)
  outrasDespesas            Decimal                    @default(0) @db.Decimal(14, 2)
  // Informações complementares do XML (infAdic/infCpl) — exibidas na conferência; fornecedores
  // do Simples costumam informar aqui o crédito de ICMS permitido (LC 123, art. 23).
  informacoesComplementares String?
  observacoes               String?
  itens                     EntradaFiscalItem[]
  parcelas                  EntradaFiscalParcela[]
  contasPagar               ContaPagar[]
  distribuicoesNfe          DistribuicaoNfeDocumento[]
  criadoEm                  DateTime                   @default(now())
  atualizadoEm              DateTime                   @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, fornecedorId])
}

model DistribuicaoNfeDocumento {
  id                 String         @id @default(cuid())
  tenantId           String
  empresaId          String
  empresa            Empresa        @relation(fields: [empresaId], references: [id])
  acbrDocumentoId    String
  acbrDistribuicaoId String?
  ambiente           AmbienteFiscal
  nsu                String?
  schema             String?
  tipoDocumento      String?
  chaveAcesso        String?
  resumo             Boolean?
  tipoEvento         String?
  numeroProtocolo    String?
  tipoNfe            Int?
  valorNfe           Decimal?       @db.Decimal(14, 2)
  dataEmissao        DateTime?
  dataRecebimento    DateTime?
  emitenteDocumento  String?
  emitenteNome       String?
  manifestacaoId     String?
  manifestacaoStatus String?
  manifestacaoEvento String?
  manifestadoEm      DateTime?
  entradaFiscalId    String?
  entradaFiscal      EntradaFiscal? @relation(fields: [entradaFiscalId], references: [id])
  xmlImportacaoId    String?
  xmlImportacao      XmlImportacao? @relation(fields: [xmlImportacaoId], references: [id])
  status             String         @default("LISTADO")
  ultimoErro         String?
  payload            Json?
  criadoEm           DateTime       @default(now())
  atualizadoEm       DateTime       @updatedAt

  @@unique([tenantId, empresaId, acbrDocumentoId])
  @@index([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, status])
}

/// Distribuição de NFS-e do Sistema Nacional (ADN, GET /contribuintes/DFe/{NSU}). Guarda as NFS-e
/// do CNPJ — emitidas por ele (papel PRESTADOR) e recebidas como tomador (papel TOMADOR) — com o XML.
/// As emitidas que ainda não estão no sistema viram NotaFiscal (notaFiscalId).
model DistribuicaoNfseDocumento {
  id                String         @id @default(cuid())
  tenantId          String
  empresaId         String
  ambiente          AmbienteFiscal
  nsu               String
  chaveAcesso       String?
  nNFSe             String?
  tipoDocumento     String?
  papel             String?
  emitenteDocumento String?
  emitenteNome      String?
  tomadorDocumento  String?
  tomadorNome       String?
  valor             Decimal?       @db.Decimal(14, 2)
  dataEmissao       DateTime?
  notaFiscalId      String?
  /// NFS-e recebida importada como despesa: id da ContaPagar gerada (idempotência do import).
  contaPagarId      String?
  status            String         @default("RECEBIDO")
  payload           Json?
  criadoEm          DateTime       @default(now())
  atualizadoEm      DateTime       @updatedAt

  @@unique([tenantId, empresaId, nsu])
  @@index([tenantId, empresaId, chaveAcesso])
  @@index([tenantId, empresaId, papel])
}

model EntradaFiscalParcela {
  id              String        @id @default(cuid())
  tenantId        String
  empresaId       String
  entradaFiscalId String
  entradaFiscal   EntradaFiscal @relation(fields: [entradaFiscalId], references: [id])
  contaPagar      ContaPagar?
  numero          String
  vencimento      DateTime
  valor           Decimal       @db.Decimal(14, 2)
  formaPagamento  String?
  /// Conta financeira do cadastro (banco/caixa/cartão) escolhida no lançamento — vai p/ ContaPagar.
  contaBancariaId String?
  origem          String        @default("XML")
  criadoEm        DateTime      @default(now())
  atualizadoEm    DateTime      @updatedAt

  @@unique([tenantId, empresaId, entradaFiscalId, numero])
  @@index([tenantId, empresaId, entradaFiscalId])
  @@index([tenantId, empresaId, vencimento])
}

model EntradaFiscalItem {
  id                              String                     @id @default(cuid())
  tenantId                        String
  empresaId                       String
  entradaFiscalId                 String
  produtoId                       String?
  entradaFiscal                   EntradaFiscal              @relation(fields: [entradaFiscalId], references: [id])
  produto                         Produto?                   @relation(fields: [produtoId], references: [id])
  itemNumero                      Int
  codigoFornecedor                String
  descricaoFornecedor             String
  gtin                            String?
  ncm                             String?
  cest                            String?
  cfop                            String?
  unidade                         String
  quantidade                      Decimal                    @db.Decimal(14, 4)
  valorUnitario                   Decimal                    @db.Decimal(14, 4)
  valorTotal                      Decimal                    @db.Decimal(14, 2)
  valorDesconto                   Decimal                    @default(0) @db.Decimal(14, 2)
  // Conversão de embalagem: 1 unidade de compra (`unidade`, ex.: CX/FD) = `fatorConversao` unidades de
  // venda (`unidadeVenda`, ex.: UN). Ao lançar, o estoque entra em unidadeVenda (quantidade × fator) e
  // o custo unitário vira valorUnitario ÷ fator. `quantidade`/`unidade` permanecem o COMERCIAL da nota
  // (fidelidade do SPED C170). Sugerido do XML (qTrib/qCom) e editável na conferência.
  fatorConversao                  Decimal                    @default(1) @db.Decimal(14, 6)
  unidadeVenda                    String?
  precoVendaDefinido              Decimal?                   @db.Decimal(14, 2)
  // Preço A PRAZO definido na conferência para o novo SKU (precoVendaDefinido é o À VISTA).
  precoVendaPrazoDefinido         Decimal?                   @db.Decimal(14, 2)
  precoMinimoDefinido             Decimal?                   @db.Decimal(14, 2)
  marcaDefinida                   String?
  produtoVinculadoAutomaticamente Boolean                    @default(false)
  confiancaVinculo                Decimal?                   @db.Decimal(8, 4)
  revisarVinculo                  Boolean                    @default(true)
  finalidade                      FinalidadeEntrada?
  finalidadeSugerida              FinalidadeEntrada?
  finalidadeOrigem                String?
  cfopEntradaDerivado             String?
  movimentaEstoque                Boolean                    @default(true)
  impostos                        EntradaFiscalItemImposto[]
  criadoEm                        DateTime                   @default(now())
  atualizadoEm                    DateTime                   @updatedAt

  @@unique([tenantId, empresaId, entradaFiscalId, itemNumero])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, codigoFornecedor])
  @@index([tenantId, empresaId, ncm])
}

model EntradaFiscalItemImposto {
  id                  String            @id @default(cuid())
  tenantId            String
  empresaId           String
  entradaFiscalItemId String
  entradaFiscalItem   EntradaFiscalItem @relation(fields: [entradaFiscalItemId], references: [id])
  tributo             TipoTributo
  cst                 String?
  csosn               String?
  cClassTrib          String?
  baseCalculo         Decimal?          @db.Decimal(14, 2)
  aliquota            Decimal?          @db.Decimal(8, 4)
  valor               Decimal?          @db.Decimal(14, 2)
  recuperavel         Boolean           @default(false)
  // Crédito de ICMS de fornecedor do Simples (LC 123, art. 23): pCredSN/vCredICMSSN do XML.
  // A nota vem SEM destaque nos itens; este é o crédito que o adquirente pode aproveitar.
  aliquotaCredSn      Decimal?          @db.Decimal(8, 4)
  valorCredSn         Decimal?          @db.Decimal(14, 2)
  dadosOriginais      Json?

  @@index([tenantId, empresaId, tributo])
  @@index([tenantId, empresaId, entradaFiscalItemId])
}

model RegraTributaria {
  id                    String             @id @default(cuid())
  tenantId              String
  empresaId             String?
  empresa               Empresa?           @relation(fields: [empresaId], references: [id])
  produtosFiscais       ProdutoFiscal[]
  nome                  String
  tributo               TipoTributo
  operacao              TipoOperacaoFiscal
  ufOrigem              String?
  ufDestino             String?
  regimeEmpresa         String?
  ncm                   String?
  cest                  String?
  cfop                  String?
  cst                   String?
  csosn                 String?
  cClassTrib            String?
  /// Código de PRODUTO da GNRE da UF de destino (ex.: DF 20 = autopeças) — usado na guia ST.
  gnreProduto           String?
  /// Código de RECEITA da GNRE da UF de destino (ex.: PR 100099 = ST por operação; consulte GnreConfigUF).
  gnreReceita           String?
  /// Tipo de documento de origem aceito pela UF (10 = nº da NF; 22 = chave — MT/PA só aceitam 22).
  gnreTipoDocOrigem     String?
  /// Detalhamento da receita exigido por algumas UFs (ex.: TO 000003, MT 000017, MA 000020).
  gnreDetalhamento      String?
  /// JSON [{codigo, valor}] dos campos extras da UF; {CHAVE}/{NUMERO} são substituídos na emissão.
  gnreCamposExtras      String?
  codigoBeneficioFiscal String?
  aliquota              Decimal?           @db.Decimal(8, 4)
  reducaoBase           Decimal?           @db.Decimal(8, 4)
  diferimento           Decimal?           @db.Decimal(8, 4)
  creditoPresumido      Decimal?           @db.Decimal(8, 4)
  mva                   Decimal?           @db.Decimal(8, 4)
  aliquotaIcmsSt        Decimal?           @db.Decimal(8, 4)
  fcp                   Decimal?           @db.Decimal(8, 4)
  formula               Json?
  vigenciaInicio        DateTime
  vigenciaFim           DateTime?
  ativo                 Boolean            @default(true)
  criadoEm              DateTime           @default(now())
  atualizadoEm          DateTime           @updatedAt

  @@index([tenantId, empresaId, tributo, operacao])
  @@index([tenantId, empresaId, ncm, ufDestino])
  @@index([tenantId, empresaId, vigenciaInicio, vigenciaFim])
}

// Regra De/Para que sugere a finalidade de um item ao importar a NF-e de entrada,
// a partir do NCM / CFOP de origem do fornecedor / fornecedor específico.
// empresaId null = regra global do tenant. Matriz de CFOP/crédito fica em código
// (src/domains/fiscal/finalidade-entrada.ts); aqui guarda-se só o mapeamento.
model RegraFinalidadeEntrada {
  id             String            @id @default(cuid())
  tenantId       String
  empresaId      String?
  nome           String
  finalidade     FinalidadeEntrada
  ncm            String?
  cfopOrigem     String?
  fornecedorId   String?
  prioridade     Int               @default(100)
  ativo          Boolean           @default(true)
  vigenciaInicio DateTime          @default(now())
  vigenciaFim    DateTime?
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, ativo])
}

/// Plano de classificação financeira GERENCIAL (não contábil): categoriza ContaPagar/ContaReceber
/// para os relatórios "pagamentos por classificação" e "fechamento mensal" (orçado × realizado).
/// Dois níveis: `grupo` (bloco do fechamento, ex.: "Custos operacionais") → classificação analítica
/// (ex.: "Mercadoria para revenda"). `codigo` é livre (o plano do cliente pode ter máscara própria).
/// `orcamentoMensal` é o valor IDEAL/meta mensal usado no fechamento (0 = sem meta).
model ClassificacaoFinanceira {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  codigo          String?
  nome            String
  grupo           String
  tipo            TipoClassificacaoFinanceira @default(DESPESA)
  orcamentoMensal Decimal        @default(0) @db.Decimal(14, 2)
  ativo           Boolean        @default(true)
  contasPagar     ContaPagar[]
  contasReceber   ContaReceber[]
  emprestimos     Emprestimo[]   @relation("EmprestimoClassificacao")
  recorrencias    DespesaRecorrente[] @relation("RecorrenciaClassificacao")
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, grupo])
}

/// Operação de ANTECIPAÇÃO de recebíveis (banco/factoring): os títulos selecionados são baixados
/// pelo valor BRUTO (crédito na conta bancária) e a taxa/deságio vira despesa financeira PAGA
/// (ContaPagar quitada, classificação "Juros de antecipação") — o líquido fica no saldo e o
/// DRE/fechamento mensal batem sem lançamento manual de taxas.
model AntecipacaoRecebivel {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  ambiente        AmbienteFiscal @default(HOMOLOGACAO)
  contaBancariaId String
  contaBancaria   ContaBancaria  @relation(fields: [contaBancariaId], references: [id])
  /// Banco/factoring onde os títulos foram antecipados (texto livre).
  instituicao     String?
  dataOperacao    DateTime
  valorBruto      Decimal        @db.Decimal(14, 2)
  valorTaxa       Decimal        @db.Decimal(14, 2)
  valorLiquido    Decimal        @db.Decimal(14, 2)
  observacoes     String?
  contaPagarTaxaId String?       @unique
  contaPagarTaxa  ContaPagar?    @relation(fields: [contaPagarTaxaId], references: [id])
  recebiveis      ContaReceber[]
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([tenantId, empresaId, dataOperacao])
}

model ContaPagar {
  id                     String                @id @default(cuid())
  tenantId               String
  empresaId              String
  empresa                Empresa               @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando a conta foi criada.
  ambiente               AmbienteFiscal        @default(HOMOLOGACAO)
  fornecedorId           String?
  pedidoCompraId         String?
  entradaFiscalId        String?
  entradaFiscalParcelaId String?               @unique
  fornecedor             Fornecedor?           @relation(fields: [fornecedorId], references: [id])
  pedidoCompra           PedidoCompra?         @relation(fields: [pedidoCompraId], references: [id])
  entradaFiscal          EntradaFiscal?        @relation(fields: [entradaFiscalId], references: [id])
  entradaFiscalParcela   EntradaFiscalParcela? @relation(fields: [entradaFiscalParcelaId], references: [id])
  descricao              String
  numeroDocumento        String?
  formaPagamento         String?
  origem                 String?
  vencimento             DateTime
  valor                  Decimal               @db.Decimal(14, 2)
  valorPago              Decimal               @default(0) @db.Decimal(14, 2)
  juros                  Decimal               @default(0) @db.Decimal(14, 2)
  multa                  Decimal               @default(0) @db.Decimal(14, 2)
  descontoBaixa          Decimal               @default(0) @db.Decimal(14, 2)
  observacoes            String?
  contaBancariaId        String?
  contaBancaria          ContaBancaria?        @relation(fields: [contaBancariaId], references: [id])
  classificacaoId        String?
  classificacao          ClassificacaoFinanceira? @relation(fields: [classificacaoId], references: [id])
  movimentos             MovimentoFinanceiro[]
  antecipacaoTaxa        AntecipacaoRecebivel?
  /// Parcela de um contrato de empréstimo/financiamento (cronograma gerado pelo contrato).
  emprestimoId           String?
  emprestimo             Emprestimo?           @relation(fields: [emprestimoId], references: [id])
  emprestimoParcela      Int?
  /// Ocorrência de uma despesa recorrente (folha, aluguel, energia...) — competência "AAAA-MM".
  recorrenciaId          String?
  recorrencia            DespesaRecorrente?    @relation(fields: [recorrenciaId], references: [id])
  recorrenciaCompetencia String?
  status                 StatusFinanceiro      @default(ABERTO)
  pagoEm                 DateTime?
  criadoEm               DateTime              @default(now())
  atualizadoEm           DateTime              @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, fornecedorId, vencimento])
  @@index([tenantId, empresaId, entradaFiscalId])
  @@index([tenantId, empresaId, classificacaoId])
  @@index([tenantId, empresaId, emprestimoId])
  @@index([tenantId, empresaId, recorrenciaId])
  // Idempotência da geração automática: uma ocorrência por recorrência+competência.
  @@unique([recorrenciaId, recorrenciaCompetencia])
}

/// DESPESA RECORRENTE (folha salarial, aluguel, energia, contador, assinaturas...): modelo que
/// gera automaticamente as ContaPagar por competência (cron + idempotência por recorrência+mês).
/// Valor VARIÁVEL = o título nasce com a estimativa (último valor) e o operador ajusta na baixa.
model DespesaRecorrente {
  id              String         @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa        @relation(fields: [empresaId], references: [id])
  ambiente        AmbienteFiscal @default(HOMOLOGACAO)
  descricao       String
  fornecedorId    String?
  fornecedor      Fornecedor?    @relation(fields: [fornecedorId], references: [id])
  /// Valor de cada ocorrência (estimativa quando valorVariavel).
  valor           Decimal        @db.Decimal(14, 2)
  /// true = valor muda todo mês (energia, folha) — o título nasce como estimativa.
  valorVariavel   Boolean        @default(false)
  /// MENSAL | BIMESTRAL | TRIMESTRAL | SEMESTRAL | ANUAL
  periodicidade   String         @default("MENSAL")
  /// Dia do vencimento (1–31, ajustado ao fim do mês curto).
  diaVencimento   Int
  /// Primeira competência (a partir deste mês as ocorrências são geradas).
  dataInicio      DateTime
  /// Última competência (null = por prazo indeterminado).
  dataFim         DateTime?
  formaPagamento  String?
  contaBancariaId String?
  contaBancaria   ContaBancaria? @relation(fields: [contaBancariaId], references: [id])
  classificacaoId String?
  classificacao   ClassificacaoFinanceira? @relation("RecorrenciaClassificacao", fields: [classificacaoId], references: [id])
  observacoes     String?
  /// ATIVA | PAUSADA | ENCERRADA
  status          String         @default("ATIVA")
  ocorrencias     ContaPagar[]
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@index([tenantId, empresaId, status])
}

/// Contrato de EMPRÉSTIMO/FINANCIAMENTO (padrão contábil: parcela = amortização do principal +
/// juros/despesa financeira). O cronograma é DETERMINÍSTICO a partir dos parâmetros (sistema de
/// amortização + taxa + nº de parcelas) e materializado como ContaPagar (uma por parcela em aberto);
/// contratos antigos entram com `parcelasJaPagas` e só as restantes viram título. O saldo devedor
/// é derivado do cronograma + parcelas pagas — nada é gravado duplicado.
model Emprestimo {
  id                   String         @id @default(cuid())
  tenantId             String
  empresaId            String
  empresa              Empresa        @relation(fields: [empresaId], references: [id])
  ambiente             AmbienteFiscal @default(HOMOLOGACAO)
  /// EMPRESTIMO | FINANCIAMENTO | CONSIGNADO | OUTRO (livre — sem lista fixa no código).
  tipo                 String         @default("EMPRESTIMO")
  /// Credor (banco/financeira/pessoa) — texto livre; opcionalmente vinculado a um fornecedor.
  instituicao          String
  fornecedorId         String?
  fornecedor           Fornecedor?    @relation(fields: [fornecedorId], references: [id])
  numeroContrato       String?
  dataContratacao      DateTime
  /// Valor liberado/financiado (principal).
  valorPrincipal       Decimal        @db.Decimal(14, 2)
  /// Taxa de juros mensal em % (ex.: 1.99). 0 = sem juros.
  taxaJurosMensal      Decimal        @default(0) @db.Decimal(8, 4)
  /// PRICE (parcelas iguais) | SAC (amortização constante) | PARCELA_INFORMADA (valor fixado no
  /// contrato, ex.: carnê) | SEM_JUROS (divide o principal igualmente).
  sistemaAmortizacao   String         @default("PRICE")
  totalParcelas        Int
  /// Contrato antigo (migração): parcelas já quitadas antes do cadastro — não viram ContaPagar.
  parcelasJaPagas      Int            @default(0)
  /// Valor da parcela quando o sistema é PARCELA_INFORMADA (carnê/contrato define o valor).
  valorParcela         Decimal?       @db.Decimal(14, 2)
  /// Vencimento da PRIMEIRA parcela do contrato (inclui as já pagas); demais mensais.
  primeiroVencimento   DateTime
  /// Conta padrão de débito das parcelas.
  contaBancariaId      String?
  contaBancaria        ContaBancaria? @relation(fields: [contaBancariaId], references: [id])
  /// Classificação financeira das parcelas (ex.: grupo Empréstimos) — escolhida pelo usuário.
  classificacaoId      String?
  classificacao        ClassificacaoFinanceira? @relation("EmprestimoClassificacao", fields: [classificacaoId], references: [id])
  observacoes          String?
  /// ATIVO | QUITADO | CANCELADO
  status               String         @default("ATIVO")
  parcelas             ContaPagar[]
  criadoEm             DateTime       @default(now())
  atualizadoEm         DateTime       @updatedAt

  @@index([tenantId, empresaId, status])
}

model ContaReceber {
  id              String                @id @default(cuid())
  tenantId        String
  empresaId       String
  empresa         Empresa               @relation(fields: [empresaId], references: [id])
  // Ambiente fiscal vigente quando a conta foi criada.
  ambiente        AmbienteFiscal        @default(HOMOLOGACAO)
  clienteId       String
  pedidoVendaId   String?
  ordemServicoId  String?
  notaFiscalId    String?
  cliente         Cliente               @relation(fields: [clienteId], references: [id])
  pedidoVenda     PedidoVenda?          @relation(fields: [pedidoVendaId], references: [id])
  ordemServico    OrdemServico?         @relation(fields: [ordemServicoId], references: [id])
  notaFiscal      NotaFiscal?           @relation(fields: [notaFiscalId], references: [id])
  descricao       String
  numeroDocumento String?
  origem          String?
  formaPagamento  String?
  vencimento      DateTime
  valor           Decimal               @db.Decimal(14, 2)
  valorPago       Decimal               @default(0) @db.Decimal(14, 2)
  juros           Decimal               @default(0) @db.Decimal(14, 2)
  multa           Decimal               @default(0) @db.Decimal(14, 2)
  descontoBaixa   Decimal               @default(0) @db.Decimal(14, 2)
  observacoes     String?
  contaBancariaId String?
  contaBancaria   ContaBancaria?        @relation(fields: [contaBancariaId], references: [id])
  classificacaoId String?
  classificacao   ClassificacaoFinanceira? @relation(fields: [classificacaoId], references: [id])
  movimentos      MovimentoFinanceiro[]
  /// Operação de antecipação que baixou este título (null = baixa normal/aberto).
  antecipacaoId   String?
  antecipacao     AntecipacaoRecebivel? @relation(fields: [antecipacaoId], references: [id])
  boleto          BoletoCobranca?
  pixCobranca     PixCobranca?
  status          StatusFinanceiro      @default(ABERTO)
  pagoEm          DateTime?
  criadoEm        DateTime              @default(now())
  atualizadoEm    DateTime              @updatedAt

  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, clienteId, vencimento])
  @@index([tenantId, empresaId, classificacaoId])
  @@index([tenantId, empresaId, antecipacaoId])
}

model NotaFiscal {
  id                        String             @id @default(cuid())
  tenantId                  String
  empresaId                 String
  empresa                   Empresa            @relation(fields: [empresaId], references: [id])
  modelo                    ModeloFiscal       @default(NFE)
  finalidade                FinalidadeNfe      @default(NORMAL)
  ambiente                  AmbienteFiscal     @default(HOMOLOGACAO)
  provedor                  ProvedorFiscal     @default(MANUAL)
  numero                    String?
  // NFS-e nacional: numero OFICIAL atribuido pela SEFIN (nNFSe), distinto do nosso nDPS (= numero).
  // Quando preenchido, e o numero exibido (vai no DANFSE e e o que o tomador conhece).
  numeroNfse                String?
  serie                     String?
  chaveAcesso               String?
  protocolo                 String?
  reciboLote                String?
  providerRef               String?
  status                    StatusNotaFiscal   @default(RASCUNHO)
  naturezaOperacao          String?
  clienteId                 String?
  pedidoVendaId             String?
  ordemServicoId            String?
  notaOrigemId              String?
  notaSubstituidaId         String?
  chaveReferenciada         String?
  cliente                   Cliente?           @relation(fields: [clienteId], references: [id])
  pedidoVenda               PedidoVenda?       @relation(fields: [pedidoVendaId], references: [id])
  ordemServico              OrdemServico?      @relation(fields: [ordemServicoId], references: [id])
  notaOrigem                NotaFiscal?        @relation("NotaDevolucao", fields: [notaOrigemId], references: [id])
  devolucoes                NotaFiscal[]       @relation("NotaDevolucao")
  // NFS-e: nota que ESTA substitui (a antiga). A antiga vira status SUBSTITUIDA.
  notaSubstituida           NotaFiscal?        @relation("NotaSubstituicao", fields: [notaSubstituidaId], references: [id])
  substitutas               NotaFiscal[]       @relation("NotaSubstituicao")
  destinatarioNome          String?
  destinatarioDocumento     String?
  destinatarioIe            String?
  destinatarioEmail         String?
  valorProdutos             Decimal            @default(0) @db.Decimal(14, 2)
  valorServicos             Decimal            @default(0) @db.Decimal(14, 2)
  valorDesconto             Decimal            @default(0) @db.Decimal(14, 2)
  valorFrete                Decimal            @default(0) @db.Decimal(14, 2)
  valorSeguro               Decimal            @default(0) @db.Decimal(14, 2)
  outrasDespesas            Decimal            @default(0) @db.Decimal(14, 2)
  valorIcms                 Decimal            @default(0) @db.Decimal(14, 2)
  valorIcmsSt               Decimal            @default(0) @db.Decimal(14, 2)
  valorFcp                  Decimal            @default(0) @db.Decimal(14, 2)
  valorIpi                  Decimal            @default(0) @db.Decimal(14, 2)
  valorPis                  Decimal            @default(0) @db.Decimal(14, 2)
  valorCofins               Decimal            @default(0) @db.Decimal(14, 2)
  valorIss                  Decimal            @default(0) @db.Decimal(14, 2)
  valorTotalTributos        Decimal            @default(0) @db.Decimal(14, 2)
  issRetido                 Boolean            @default(false)
  valorIrRetido             Decimal            @default(0) @db.Decimal(14, 2)
  valorPisRetido            Decimal            @default(0) @db.Decimal(14, 2)
  valorCofinsRetido         Decimal            @default(0) @db.Decimal(14, 2)
  valorCsllRetido           Decimal            @default(0) @db.Decimal(14, 2)
  valorInssRetido           Decimal            @default(0) @db.Decimal(14, 2)
  valorRetidoTotal          Decimal            @default(0) @db.Decimal(14, 2)
  valorLiquido              Decimal            @default(0) @db.Decimal(14, 2)
  total                     Decimal            @default(0) @db.Decimal(14, 2)
  formaPagamento            String?
  condicaoPagamento         String?
  informacoesComplementares String?
  motivo                    String?
  xml                       String?
  xmlUrl                    String?
  danfeUrl                  String?
  emitidaEm                 DateTime?
  autorizadaEm              DateTime?
  canceladaEm               DateTime?
  itens                     NotaFiscalItem[]
  eventos                   NotaFiscalEvento[]
  guiasRecolhimento         GuiaRecolhimento[]
  contasReceber             ContaReceber[]
  criadoEm                  DateTime           @default(now())
  atualizadoEm              DateTime           @updatedAt

  @@unique([tenantId, empresaId, chaveAcesso])
  @@unique([tenantId, empresaId, modelo, serie, numero])
  @@index([tenantId, empresaId, status])
  @@index([tenantId, empresaId, modelo, status])
  @@index([tenantId, empresaId, clienteId])
}

