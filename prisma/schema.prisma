// Finalidade/destinação de um item recebido em NF-e de entrada. Determina o CFOP de
// entrada, o direito a crédito (ICMS/PIS/COFINS) e se o item movimenta estoque.
enum FinalidadeEntrada {
  REVENDA // Mercadoria para revenda (entra no estoque, credita)
  USO_CONSUMO // Material de uso/consumo (despesa; ICMS sem crédito até 2033)
  IMOBILIZADO // Bem do ativo imobilizado (crédito de ICMS via CIAP 48 parcelas)
  INDUSTRIALIZACAO // Insumo/matéria-prima para produção (entra como INSUMO, credita)
  DEVOLUCAO_VENDA // Cliente devolveu mercadoria vendida — recupera o ICMS/IPI debitado na venda (CFOP 1.202/1.201/1.411)
  TRANSFERENCIA // Entrada por transferência entre estabelecimentos do mesmo titular (CFOP 1.152/1.151; crédito da origem — LC 204/2023)
  RETORNO_INDUSTRIALIZACAO // Retorno de remessa para industrialização/beneficiamento por terceiro (CFOP 1.902/1.124)
  BONIFICACAO // Mercadoria recebida em bonificação/brinde/doação, sem pagamento (CFOP 1.910)
  MATERIAL_SERVICO_ICMS // Material para uso na prestação de serviço sujeito a ICMS (CFOP 1.126/2.126) — credita ICMS
  MATERIAL_SERVICO_ISS // Material para uso na prestação de serviço sujeito a ISSQN (CFOP 1.128/2.128) — NÃO credita ICMS
  COMBUSTIVEL_LUBRIFICANTE // Compra de combustível/lubrificante por consumidor final (CFOP 1.653/2.653) — ICMS-ST/monofásico, sem crédito
}

enum ProvedorIa {
  OPENROUTER
}

enum AgentRole {
  GESTOR
  VENDEDOR
  CLIENTE
}

enum MensagemPapel {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

enum ProvedorWhatsapp {
  ZAPI
  /// Zernio (camada sobre a API OFICIAL da Meta / WABA): conversa iniciada pela empresa exige
  /// template aprovado; mensagem livre e PDF só na janela de 24h após resposta do cliente.
  ZERNIO
}

model Tenant {
  id                       String                   @id @default(cuid())
  nome                     String
  slug                     String                   @unique
  ativo                    Boolean                  @default(true)
  /// Plano comercial do cliente: COMPLETO (ERP inteiro) ou EMISSOR (só emissão de NF-e/NFS-e +
  /// clientes/produtos — MEI e Simples que querem um emissor de notas). É o MESMO sistema: o
  /// upgrade religa os módulos. O preset de flags é aplicado ao trocar o plano (platform-admin).
  plano                    String                   @default("COMPLETO")
  /// Fim do período de teste (trial). null = sem trial (assinante). Vencido → o ERP bloqueia
  /// com aviso até o dono do SaaS estender/limpar.
  trialFimEm               DateTime?
  /// Assinatura recorrente no Asaas (mensalidade). Pagamento confirmado limpa o trial (webhook).
  assinaturaAsaasId        String?
  // Módulo Loja Virtual liberado pelo dono do SaaS (painel /admin). Quando false, as lojas das
  // empresas deste cliente não ficam acessíveis publicamente.
  lojaHabilitada           Boolean                  @default(false)
  // Módulo de IA liberado pelo dono do SaaS. Ligado por padrão; quando false, as funções de IA
  // (sugestões, assistente) ficam bloqueadas para este cliente.
  iaHabilitada             Boolean                  @default(true)
  // Módulo SPED Fiscal (EFD ICMS/IPI) liberado pelo dono do SaaS. Desligado por padrão;
  // quando false, as telas e APIs de geração do SPED ficam bloqueadas para este cliente.
  spedFiscalHabilitado     Boolean                  @default(false)
  // Módulo Expedição (recibo de retirada de mercadoria) liberado pelo dono do SaaS.
  // Desligado por padrão — é para lojas com balcão de retirada (material de construção, autopeças).
  expedicaoHabilitada      Boolean                  @default(false)
  // Módulos liberáveis pelo dono do SaaS (painel /admin). LIGADOS por padrão (true) para não
  // tirar acesso de quem já usa — o dono DESLIGA o que cada cliente não contrata. Cada um esconde
  // o item no menu (ErpShell.podeVer via HREF_FLAG) e bloqueia o acesso direto pela URL.
  pdvTelaCheiaHabilitado   Boolean                  @default(true) // /pdv (PDV em tela cheia)
  vendaBalcaoHabilitada    Boolean                  @default(true) // atendimento: tipo Venda balcão
  pedidoFaturadoHabilitado Boolean                  @default(true) // atendimento: tipo Pedido faturado
  ordemServicoHabilitada   Boolean                  @default(true) // atendimento OS + menu Ordens de Serviço (/erp/os)
  orcamentoHabilitado      Boolean                  @default(true) // atendimento Orçamento + menu Orçamentos
  financeiroHabilitado     Boolean                  @default(true) // /erp/financeiro (contas a pagar/receber)
  fiscalHabilitado         Boolean                  @default(true) // /erp/fiscal (NF-e emitidas)
  gastosHabilitado         Boolean                  @default(true) // /erp/gastos (gastos por cupom)
  cosmosHabilitado         Boolean                  @default(true) // /erp/configuracoes/cosmos (catálogo Cosmos)
  whatsappHabilitado       Boolean                  @default(true) // /erp/configuracoes/whatsapp
  empresas                 Empresa[]
  vinculos                 UsuarioVinculo[]
  perfis                   Perfil[]
  auditorias               Auditoria[]
  configuracoesIa          ConfiguracaoIa[]
  configuracoesIntegracao  ConfiguracaoIntegracao[]
  conversasAgente          ConversaAgente[]
  chavesApiAgente          ChaveApiAgente[]
  telefonesAgente          AgenteTelefone[]
  configWhatsapp           ConfiguracaoWhatsapp[]
  configTelegram           ConfiguracaoTelegram[]
  vinculosTelegram         TelegramVinculo[]
  configEmail              ConfiguracaoEmail[]
  criadoEm                 DateTime                 @default(now())
  atualizadoEm             DateTime                 @updatedAt
}

model Empresa {
  id                        String                     @id @default(cuid())
  tenantId                  String
  tenant                    Tenant                     @relation(fields: [tenantId], references: [id])
  razaoSocial               String
  nomeFantasia              String?
  cnpj                      String
  inscricaoEstadual         String?
  inscricaoMunicipal        String?
  status                    StatusEmpresa              @default(ATIVA)
  /// Exigir código 2FA (WhatsApp) no login dos usuários desta empresa — controlado no /admin.
  exigir2fa                 Boolean                    @default(false)
  matriz                    Boolean                    @default(false)
  vinculos                  UsuarioVinculo[]
  clientes                  Cliente[]
  fornecedores              Fornecedor[]
  categorias                ProdutoCategoria[]
  marcas                    ProdutoMarca[]
  produtos                  Produto[]
  tabelasPreco              TabelaPreco[]
  depositos                 Deposito[]
  pedidosVenda              PedidoVenda[]
  orcamentos                Orcamento[]
  ordensServico             OrdemServico[]
  tecnicos                  Tecnico[]
  pedidosCompra             PedidoCompra[]
  contasPagar               ContaPagar[]
  contasReceber             ContaReceber[]
  classificacoesFinanceiras ClassificacaoFinanceira[]
  antecipacoesRecebiveis    AntecipacaoRecebivel[]
  emprestimos               Emprestimo[]
  despesasRecorrentes       DespesaRecorrente[]
  guiasRecolhimento         GuiaRecolhimento[]
  notasFiscais              NotaFiscal[]
  xmlImportacoes            XmlImportacao[]
  entradasFiscais           EntradaFiscal[]
  distribuicoesNfe          DistribuicaoNfeDocumento[]
  regrasTributarias         RegraTributaria[]
  configuracoesIa           ConfiguracaoIa[]
  configuracoesIntegracao   ConfiguracaoIntegracao[]
  configuracaoFiscal        ConfiguracaoFiscal?
  certificadoDigital        CertificadoDigital?
  sequenciasFiscais         SequenciaFiscal[]
  spedConfiguracao          SpedConfiguracao?
  spedArquivos              SpedArquivo[]
  spedXmlDocumentos         SpedXmlDocumento[]
  ciapBens                  CiapBem[]
  contasBancarias           ContaBancaria[]
  maquinasCartao            MaquinaCartao[]
  formasPagamento           FormaPagamento[]
  movimentosFinanceiros     MovimentoFinanceiro[]
  vendedores                Vendedor[]
  comissoesVenda            ComissaoVenda[]
  expedicaoRetiradas        ExpedicaoRetirada[]
  inventarios               Inventario[]
  auditorias                Auditoria[]
  conversasAgente           ConversaAgente[]
  gastos                    Gasto[]
  chavesApiAgente           ChaveApiAgente[]
  telefonesAgente           AgenteTelefone[]
  configWhatsapp            ConfiguracaoWhatsapp[]
  configTelegram            ConfiguracaoTelegram[]
  vinculosTelegram          TelegramVinculo[]
  configEmail               ConfiguracaoEmail[]
  enderecoLogradouro        String?
  enderecoNumero            String?
  enderecoComplemento       String?
  enderecoBairro            String?
  enderecoCidade            String?
  enderecoUf                String?
  enderecoCep               String?
  codigoMunicipioIbge       String?
  telefone                  String?
  email                     String?
  regimeTributario          RegimeTributario           @default(SIMPLES_NACIONAL)
  /// Anexo do Simples Nacional (1=Comércio, 2=Indústria, 3/4/5=Serviços) — apuração do DAS.
  simplesAnexo              Int?
  /// Anexo da receita de SERVIÇOS (empresa mista: revenda no Anexo I/II + serviços no III/IV/V).
  simplesAnexoServicos      Int?
  /// Folha de salários MENSAL média (pró-labore + salários + encargos) — Fator R (folha 12m/RBT12
  /// >= 28% leva serviços do Anexo V para o III). Informativo, preenchido com o contador.
  simplesFolhaMensal        Decimal?                   @db.Decimal(14, 2)
  tipoNegocio               TipoNegocio                @default(AMBOS)
  segmento                  SegmentoEmpresa            @default(GERAL)
  // Identidade visual (branding) exibida no sistema — não confundir com a logo fiscal (DANFE).
  // logoSistema é um data URL (base64) da imagem; corDestaque é um hex (#rrggbb).
  logoSistema               String?
  corDestaque               String?
  // Identificador da loja virtual na URL (/loja/{slugLoja}). Único entre todas as empresas.
  slugLoja                  String?                    @unique
  // Regra de operação: quando true, permite saída/venda de produtos sem saldo (estoque negativo)
  // para toda a empresa. Por produto, permiteEstoqueNegativo/permiteVendaSobEncomenda ainda valem.
  permiteVendaSemEstoque    Boolean                    @default(false)
  // Quando true, o atendimento permite "Finalizar direto + NFC-e/NF-e" (emite sem passar pelo
  // caixa). Padrão false: TODA venda vai para o CAIXA receber o pagamento e emitir.
  permiteVendaDiretaBalcao  Boolean                    @default(false)
  // Quando true, libera fechar a venda só com RECIBO (cupom não fiscal) — sem emitir NF-e/NFC-e.
  // Estoque e financeiro rodam normalmente. Decisão operacional da empresa cliente (risco fiscal).
  permiteVendaNaoFiscal     Boolean                    @default(false)
  // % de desconto que QUALQUER vendedor pode aplicar sem pedir senha de admin. Acima disso
  // (item OU global), a UI exige autorização. 0 (padrão) = todo desconto exige senha.
  descontoSemAutorizacaoPct Decimal                    @default(0) @db.Decimal(5, 2)
  // Margens (%) PADRÃO sobre o custo para sugerir os preços à vista e a prazo no cadastro de
  // produto e na importação de XML (NF-e). null = não sugerir preço automaticamente.
  margemPadraoVistaPct      Decimal?                   @db.Decimal(8, 4)
  margemPadraoPrazoPct      Decimal?                   @db.Decimal(8, 4)
  criadoEm                  DateTime                   @default(now())
  atualizadoEm              DateTime                   @updatedAt

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

// Tipo de negócio da empresa (cliente do ERP). Define o modo de PDV recomendado e quais
// módulos do menu são relevantes. VENDA = só mercadoria; SERVICO = só serviço; AMBOS = os dois.
enum TipoNegocio {
  VENDA
  SERVICO
  AMBOS
}

// Ramo da empresa. Ativa recursos específicos do catálogo sem poluir os demais segmentos —
// ex.: AUTOPECAS habilita a aplicação veicular ("que veículo a peça serve") no cadastro.
enum SegmentoEmpresa {
  GERAL
  AUTOPECAS
  MATERIAL_CONSTRUCAO
  MERCADO
}

model ConfiguracaoIa {
  id                 String     @id @default(cuid())
  tenantId           String
  empresaId          String
  tenant             Tenant     @relation(fields: [tenantId], references: [id])
  empresa            Empresa    @relation(fields: [empresaId], references: [id])
  provedor           ProvedorIa @default(OPENROUTER)
  ativo              Boolean    @default(false)
  modelo             String     @default("openai/gpt-4o-mini")
  chaveCriptografada String
  chaveFinal         String?
  observacoes        String?
  testadoEm          DateTime?
  ultimoErro         String?
  criadoEm           DateTime   @default(now())
  atualizadoEm       DateTime   @updatedAt

  @@unique([tenantId, empresaId, provedor])
  @@index([tenantId, empresaId])
}

// Credenciais de integrações externas por empresa (ex.: catálogo Cosmos/Bluesoft). A chave de
// acesso é guardada criptografada (mesmo padrão da ConfiguracaoIa). Genérica para novos provedores.
model ConfiguracaoIntegracao {
  id                 String    @id @default(cuid())
  tenantId           String
  empresaId          String
  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  empresa            Empresa   @relation(fields: [empresaId], references: [id])
  provedor           String
  ativo              Boolean   @default(false)
  chaveCriptografada String
  chaveFinal         String?
  observacoes        String?
  testadoEm          DateTime?
  ultimoErro         String?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  @@unique([tenantId, empresaId, provedor])
  @@index([tenantId, empresaId])
}

/// Tabela oficial de NCM (referência global, sem tenant). Usada para ancorar as sugestões de
/// NCM da IA (RAG + validação): a IA só pode escolher códigos que existam aqui.
model Ncm {
  codigo         String   @id
  descricao      String
  /// Descrição normalizada (sem HTML/acentos, minúscula) para busca por palavra-chave (RAG).
  descricaoBusca String   @default("")
  atualizadoEm   DateTime @default(now())

  @@index([descricaoBusca])
}

/// Categorias-padrão de produto (GLOBAL, compartilhadas por todas as empresas). Fonte da lista
/// padrão no seletor e no grounding da IA. Cada empresa ainda pode criar categorias próprias em
/// ProdutoCategoria (por empresa) — o seletor mostra as padrão + as próprias.
model CategoriaPadrao {
  slug         String   @id
  nome         String
  atualizadoEm DateTime @default(now())
}

/// Unidades de medida padrão (GLOBAL, compartilhadas por todas as empresas).
model UnidadeMedida {
  codigo       String   @id
  nome         String
  atualizadoEm DateTime @default(now())
}

/// Códigos fiscais de referência (GLOBAL): CFOP, CST_ICMS, CSOSN, ORIGEM, CST_PIS, CST_COFINS,
/// CST_IPI, NBS, LC116. Fonte das descrições e dos seletores nas telas fiscais.
model CodigoFiscal {
  tipo         String
  codigo       String
  descricao    String
  atualizadoEm DateTime @default(now())

  @@id([tipo, codigo])
  @@index([tipo])
}

/// Credenciais do provedor de emissão fiscal no nível da PLATAFORMA (do dono do SaaS), por
/// ambiente (homologação/produção). No ACBr o client_id/client_secret são da aplicação, não por
/// empresa — todas as empresas emitem com estas credenciais. Segredos criptografados.
model PlataformaProvedorFiscal {
  provedor                  String
  ambiente                  AmbienteFiscal
  baseUrl                   String?
  clientIdCriptografado     String?
  clientSecretCriptografado String?
  clientIdFinal             String?
  secretFinal               String?
  // Provedores baseados em token (Spedy, Focus NFe, NFe.io, PlugNotas, Webmania).
  tokenCriptografado        String?
  tokenFinal                String?
  ativo                     Boolean        @default(true)
  atualizadoEm              DateTime       @updatedAt

  @@id([provedor, ambiente])
}

/// Planos comerciais do SaaS, EDITÁVEIS pelo dono em /admin/planos (nada de preço hardcoded).
/// O `codigo` casa com Tenant.plano; o limite de notas é aplicado na emissão fiscal.
model PlataformaPlano {
  codigo         String   @id
  nome           String
  descricao      String?
  precoMensal    Decimal  @default(0) @db.Decimal(10, 2)
  /// Notas fiscais (emissões aceitas na SEFAZ/SEFIN) por mês. null = ilimitado.
  limiteNotasMes Int?
  trialDias      Int      @default(7)
  ativo          Boolean  @default(true)
  atualizadoEm   DateTime @updatedAt
}

/// Configuração única (global) da plataforma. Hoje guarda qual provedor de emissão está ativo.
model PlataformaConfiguracao {
  id                  String   @id @default("default")
  provedorFiscalAtivo String   @default("ACBR")
  atualizadoEm        DateTime @updatedAt
}

/// Config de PLATAFORMA do módulo de CRÉDITO (revenda de consultas de bureau). É a "conta da casa"
/// (Valleteclab), NÃO por tenant: gateway de cobrança da plataforma (Asaas — recarga dos tenants) +
/// bureau (ApiBrasil, conta mestre) + preços de revenda. Segredos criptografados (secret-crypto).
model PlataformaCredito {
  id                   String   @id @default("default")
  // Asaas — cobrança da plataforma (tenant paga a Valleteclab a recarga de créditos).
  asaasApiKeyCripto    String?
  asaasWalletId        String?
  asaasSandbox         Boolean  @default(true)
  asaasWebhookToken    String?
  // ApiBrasil — bureau de crédito (conta mestre da plataforma).
  apibrasilTokenCripto String?
  /// Endpoint (path ou URL) de cada produto. `apibrasilDevicePF/PJ` reaproveitados como endpoint.
  apibrasilDevicePF    String?
  apibrasilDevicePJ    String?
  /// Slug do `tipo` (produto) no corpo da requisição — do painel ApiBrasil (ex.: boa-vista-acerta-pf).
  apibrasilTipoPF      String?
  apibrasilTipoPJ      String?
  apibrasilSandbox     Boolean  @default(true)
  // Preços de REVENDA por consulta (o que o tenant paga; a margem é sobre o custo ApiBrasil).
  precoConsultaPF      Decimal  @default(0) @db.Decimal(10, 2)
  precoConsultaPJ      Decimal  @default(0) @db.Decimal(10, 2)
  // Validade do cache de uma consulta (dias) antes de sugerir reconsultar.
  validadeConsultaDias Int      @default(60)
  atualizadoEm         DateTime @updatedAt
}

/// Carteira de créditos de CONSULTA (pré-pago), em reais, por tenant. Recarrega via Pix (Asaas) e
/// debita o preço de revenda a cada consulta de crédito. O saldo é da PLATAFORMA (não é banco do tenant).
model CarteiraCredito {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  saldo           Decimal  @default(0) @db.Decimal(14, 2)
  /// Cliente do Asaas (pagador) desta carteira — reusado nas recargas.
  asaasCustomerId String?
  atualizadoEm    DateTime @updatedAt
  criadoEm        DateTime @default(now())
}

/// Pedido de RECARGA da carteira via Pix (Asaas). Confirmação em tempo real pelo webhook credita o saldo.
model RecargaCredito {
  id             String    @id @default(cuid())
  tenantId       String
  empresaId      String?
  valor          Decimal   @db.Decimal(14, 2)
  /// PENDENTE → CONFIRMADA (paga, saldo creditado) | EXPIRADA | CANCELADA
  status         String    @default("PENDENTE")
  asaasPaymentId String?   @unique
  pixPayload     String?
  pixQrBase64    String?
  expiraEm       DateTime?
  pagoEm         DateTime?
  usuarioId      String?
  criadoEm       DateTime  @default(now())

  @@index([tenantId, status])
}

/// Consulta de crédito (bureau ApiBrasil) — HISTÓRICO + CACHE + CUSTO num só lugar. O resultado
/// normalizado (score/faixa/decisão/limite/restrições) alimenta a tela e o gate de venda a prazo;
/// dentro de `validoAte` a consulta é reusada sem custo. `bruto` guarda a resposta original.
model ConsultaCredito {
  id                         String    @id @default(cuid())
  tenantId                   String
  empresaId                  String?
  clienteId                  String?
  documento                  String
  tipoPessoa                 String
  produto                    String
  custoRevenda               Decimal   @db.Decimal(10, 2)
  score                      Int?
  faixa                      String?
  probabilidadeInadimplencia Decimal?  @db.Decimal(6, 2)
  decisao                    String?
  limiteRecomendado          Decimal?  @db.Decimal(14, 2)
  temRestricao               Boolean   @default(false)
  protocolo                  String?
  pdfUrl                     String?
  resultado                  Json
  bruto                      Json?
  validoAte                  DateTime?
  usuarioId                  String?
  consultadoEm               DateTime  @default(now())

  @@index([tenantId, documento])
  @@index([clienteId])
}

/// Notificação para um usuário (sino no topo do ERP). Notificar um SETOR = uma linha por usuário
/// do setor (fan-out). Tempo real via canal "notificacoes".
model Notificacao {
  id               String   @id @default(cuid())
  tenantId         String
  empresaId        String
  destinoUsuarioId String
  tipo             String   @default("GERAL")
  titulo           String
  mensagem         String
  link             String?
  lida             Boolean  @default(false)
  criadoEm         DateTime @default(now())

  @@index([destinoUsuarioId, lida])
  @@index([tenantId, empresaId, criadoEm])
}

/// Chat interno 1-a-1 entre usuários. Tempo real via canal "chat".
model MensagemInterna {
  id            String   @id @default(cuid())
  tenantId      String
  empresaId     String
  deUsuarioId   String
  paraUsuarioId String
  texto         String
  lida          Boolean  @default(false)
  criadoEm      DateTime @default(now())

  @@index([paraUsuarioId, lida])
  @@index([deUsuarioId, paraUsuarioId, criadoEm])
}

/// CEST (Código Especificador da Substituição Tributária) — GLOBAL. `ncms` lista os NCMs aos
/// quais o CEST se aplica (usado para ancorar a sugestão de CEST por NCM, inclusive na IA).
model Cest {
  codigo       String   @id
  descricao    String
  ncms         String[]
  atualizadoEm DateTime @default(now())
}

/// Municípios do IBGE (GLOBAL): código IBGE de 7 dígitos + nome + UF. Valida/preenche o município
/// na NF-e (emitente/destinatário) e alimenta seletores de endereço.
model Municipio {
  codigo       String   @id
  nome         String
  uf           String
  atualizadoEm DateTime @default(now())

  @@index([uf])
  @@index([nome])
}

/// Cache de consultas ao catálogo Cosmos por GTIN (global — GTIN é universal). Evita gastar
/// a cota diária consultando o mesmo código de barras mais de uma vez.
model CosmosCache {
  gtin      String   @id
  descricao String?
  ncm       String?
  cest      String?
  marca     String?
  thumbnail String?
  buscadoEm DateTime @default(now())
}

model Usuario {
  id              String           @id @default(cuid())
  nome            String
  email           String           @unique
  senhaHash       String
  status          StatusUsuario    @default(ATIVO)
  plataformaAdmin Boolean          @default(false)
  /// WhatsApp (só dígitos, com DDD) — recebe o código 2FA quando a empresa exigir.
  whatsapp        String?
  /// Proteção contra força bruta: tentativas falhas seguidas e bloqueio temporário.
  loginFalhas     Int              @default(0)
  bloqueadoAte    DateTime?
  vinculos        UsuarioVinculo[]
  auditorias      Auditoria[]
  sessoes         Sessao[]
  desafios2fa     Desafio2fa[]
  ultimoAcessoEm  DateTime?
  /// Última troca de senha (auditoria de segurança — exibida em Minha conta → Segurança).
  senhaAtualizadaEm DateTime?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
}

/// Desafio 2FA pendente: código de 6 dígitos (hash) enviado por WhatsApp, validade curta.
model Desafio2fa {
  id         String    @id @default(cuid())
  usuarioId  String
  usuario    Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  codigoHash String
  expiraEm   DateTime
  tentativas Int       @default(0)
  usadoEm    DateTime?
  criadoEm   DateTime  @default(now())

  @@index([usuarioId])
}

model Sessao {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  // Escopo (tenant/empresa) da sessão. Nulo para o dono da plataforma, que não
  // pertence a nenhum cliente e acessa apenas o painel /admin.
  tenantId  String?
  empresaId String?
  tokenHash String   @unique
  expiraEm  DateTime
  userAgent String?
  criadoEm  DateTime @default(now())

  @@index([usuarioId])
}

model UsuarioVinculo {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String?
  usuarioId    String
  perfilId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  empresa      Empresa? @relation(fields: [empresaId], references: [id])
  usuario      Usuario  @relation(fields: [usuarioId], references: [id])
  perfil       Perfil   @relation(fields: [perfilId], references: [id])
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([tenantId, empresaId, usuarioId, perfilId])
  @@index([tenantId, empresaId])
  @@index([usuarioId])
}

model Perfil {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  nome         String
  descricao    String?
  vinculos     UsuarioVinculo[]
  permissoes   Permissao[]
  criadoEm     DateTime         @default(now())
  atualizadoEm DateTime         @updatedAt

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model Permissao {
  id       String   @id @default(cuid())
  tenantId String
  perfilId String
  modulo   String
  acao     String
  perfil   Perfil   @relation(fields: [perfilId], references: [id])
  criadoEm DateTime @default(now())

  @@unique([tenantId, modulo, acao, perfilId])
  @@index([tenantId])
}

model Auditoria {
  id         String   @id @default(cuid())
  tenantId   String
  empresaId  String?
  usuarioId  String?
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  empresa    Empresa? @relation(fields: [empresaId], references: [id])
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  entidade   String
  entidadeId String
  acao       String
  payload    Json?
  ip         String?
  userAgent  String?
  criadoEm   DateTime @default(now())

  @@index([tenantId, empresaId])
  @@index([entidade, entidadeId])
}

model Cliente {
  id                String            @id @default(cuid())
  tenantId          String
  empresaId         String
  empresa           Empresa           @relation(fields: [empresaId], references: [id])
  razaoSocial       String
  nomeFantasia      String?
  documento         String
  inscricaoEstadual String?
  status            StatusCliente     @default(PENDENTE_APROVACAO)
  segmento          String?
  limiteCredito     Decimal           @default(0) @db.Decimal(14, 2)
  creditoUsado      Decimal           @default(0) @db.Decimal(14, 2)
  /// Venda FATURADA (boleto/crediário) liberada para este cliente. Só o perfil FINANCEIRO libera;
  /// sem isso, o caixa/PDV bloqueia venda a prazo e pede liberação ao financeiro.
  vendaFaturadaLiberada   Boolean   @default(false)
  vendaFaturadaLiberadaPor String?
  vendaFaturadaLiberadaEm DateTime?
  vendaFaturadaObs        String?
  condicaoPagamento String?
  tabelaPrecoId     String?
  tabelaPreco       TabelaPreco?      @relation(fields: [tabelaPrecoId], references: [id])
  contatos          ClienteContato[]
  enderecos         ClienteEndereco[]
  pedidosVenda      PedidoVenda[]
  orcamentos        Orcamento[]
  ordensServico     OrdemServico[]
  contasReceber     ContaReceber[]
  notasFiscais      NotaFiscal[]
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt

  @@unique([tenantId, documento])
  @@index([tenantId, empresaId])
}

model ClienteContato {
  id           String   @id @default(cuid())
  tenantId     String
  empresaId    String
  clienteId    String
  cliente      Cliente  @relation(fields: [clienteId], references: [id])
  nome         String
  email        String?
  telefone     String?
  whatsapp     String?
  cargo        String?
  principal    Boolean  @default(false)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model ClienteEndereco {
  id                  String   @id @default(cuid())
  tenantId            String
  empresaId           String
  clienteId           String
  cliente             Cliente  @relation(fields: [clienteId], references: [id])
  apelido             String
  cep                 String
  logradouro          String
  numero              String?
  complemento         String?
  bairro              String?
  cidade              String
  uf                  String
  codigoMunicipioIbge String?
  referencia          String?
  padrao              Boolean  @default(false)
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@index([tenantId, empresaId])
}

model TabelaPreco {
  id           String            @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa           @relation(fields: [empresaId], references: [id])
  nome         String
  descricao    String?
  clientes     Cliente[]
  itens        TabelaPrecoItem[]
  criadoEm     DateTime          @default(now())
  atualizadoEm DateTime          @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model TabelaPrecoItem {
  id               String      @id @default(cuid())
  tenantId         String
  empresaId        String
  tabelaPrecoId    String
  produtoId        String
  tabelaPreco      TabelaPreco @relation(fields: [tabelaPrecoId], references: [id])
  produto          Produto     @relation(fields: [produtoId], references: [id])
  preco            Decimal     @db.Decimal(14, 2)
  quantidadeMinima Int         @default(1)

  @@unique([tenantId, tabelaPrecoId, produtoId, quantidadeMinima])
  @@index([tenantId, empresaId])
}

model ProdutoCategoria {
  id               String             @id @default(cuid())
  tenantId         String
  empresaId        String
  empresa          Empresa            @relation(fields: [empresaId], references: [id])
  nome             String
  slug             String
  categoriaPaiId   String?
  categoriaPai     ProdutoCategoria?  @relation("ArvoreCategoria", fields: [categoriaPaiId], references: [id])
  categoriasFilhas ProdutoCategoria[] @relation("ArvoreCategoria")
  produtos         Produto[]
  criadoEm         DateTime           @default(now())
  atualizadoEm     DateTime           @updatedAt

  @@unique([tenantId, empresaId, slug])
  @@index([tenantId, empresaId])
}

model ProdutoMarca {
  id           String    @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  nome         String
  produtos     Produto[]
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model Produto {
  id                       String                  @id @default(cuid())
  tenantId                 String
  empresaId                String
  empresa                  Empresa                 @relation(fields: [empresaId], references: [id])
  sku                      String
  nome                     String
  descricao                String?
  descricaoComercial       String?
  tipo                     TipoProduto             @default(PRODUTO)
  codigoOriginal           String?
  codigoFabricante         String?
  gtin                     String?
  categoriaId              String
  marcaId                  String?
  categoria                ProdutoCategoria        @relation(fields: [categoriaId], references: [id])
  marca                    ProdutoMarca?           @relation(fields: [marcaId], references: [id])
  unidade                  String                  @default("UN")
  unidadeCompra            String                  @default("UN")
  fatorConversaoCompra     Decimal                 @default(1) @db.Decimal(14, 6)
  pesoKg                   Decimal?                @db.Decimal(10, 3)
  pesoBrutoKg              Decimal?                @db.Decimal(10, 3)
  alturaCm                 Decimal?                @db.Decimal(10, 3)
  larguraCm                Decimal?                @db.Decimal(10, 3)
  comprimentoCm            Decimal?                @db.Decimal(10, 3)
  ncm                      String?
  cest                     String?
  cfop                     String?
  origem                   String?
  precoCusto               Decimal                 @default(0) @db.Decimal(14, 2)
  ultimoCusto              Decimal                 @default(0) @db.Decimal(14, 2)
  custoMedio               Decimal                 @default(0) @db.Decimal(14, 4)
  // precoVenda é o preço À VISTA (usado por PDV/vendas). precoVendaPrazo é o preço A PRAZO
  // (crediário/parcelado); 0 = sem preço a prazo definido (vale o à vista).
  precoVenda               Decimal                 @default(0) @db.Decimal(14, 2)
  precoVendaPrazo          Decimal                 @default(0) @db.Decimal(14, 2)
  precoMinimo              Decimal                 @default(0) @db.Decimal(14, 2)
  margemAlvoPercentual     Decimal?                @db.Decimal(8, 4)
  // Margens (%) sobre o custo para formação automática dos preços: preço = custo × (1 + margem/100).
  // Memorizadas no produto para recalcular os preços quando o custo mudar (nova compra).
  margemVistaPercentual    Decimal?                @db.Decimal(8, 4)
  margemPrazoPercentual    Decimal?                @db.Decimal(8, 4)
  quantidadeMinima         Int                     @default(1)
  controlaLote             Boolean                 @default(false)
  controlaSerie            Boolean                 @default(false)
  controlaValidade         Boolean                 @default(false)
  permiteEstoqueNegativo   Boolean                 @default(false)
  permiteVendaSobEncomenda Boolean                 @default(false)
  ativoCompra              Boolean                 @default(true)
  ativoVenda               Boolean                 @default(true)
  ativo                    Boolean                 @default(true)
  visivelEcommerce         Boolean                 @default(true)
  imagens                  ProdutoImagem[]
  aplicacoes               ProdutoAplicacao[]
  fiscal                   ProdutoFiscal?
  fornecedores             ProdutoFornecedor[]
  lotes                    EstoqueLote[]
  series                   EstoqueSerie[]
  saldosEstoque            EstoqueSaldo[]
  movimentosEstoque        EstoqueMovimento[]
  reservasEstoque          EstoqueReserva[]
  entradasFiscaisItens     EntradaFiscalItem[]
  itensPedidoVenda         PedidoVendaItem[]
  itensOrcamento           OrcamentoItem[]
  pecasServico             OrdemServicoPeca[]
  itensCompra              PedidoCompraItem[]
  itensPreco               TabelaPrecoItem[]
  itensNotaFiscal          NotaFiscalItem[]
  itensInventario          InventarioItem[]
  itensRetirada            ExpedicaoRetiradaItem[]
  criadoEm                 DateTime                @default(now())
  atualizadoEm             DateTime                @updatedAt

  @@unique([tenantId, empresaId, sku])
  @@index([tenantId, empresaId])
  @@index([tenantId, empresaId, nome])
  @@index([tenantId, empresaId, gtin])
  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, categoriaId])
  @@index([tenantId, empresaId, marcaId])
}

model ProdutoImagem {
  id        String  @id @default(cuid())
  tenantId  String
  empresaId String
  produtoId String
  produto   Produto @relation(fields: [produtoId], references: [id])
  url       String
  textoAlt  String?
  ordem     Int     @default(0)

  @@index([tenantId, empresaId])
}

model ProdutoAplicacao {
  id          String  @id @default(cuid())
  tenantId    String
  empresaId   String
  produtoId   String
  produto     Produto @relation(fields: [produtoId], references: [id])
  marca       String?
  modelo      String?
  anoFaixa    String?
  observacoes String?

  @@index([tenantId, empresaId])
}

model ProdutoFiscal {
  id                    String             @id @default(cuid())
  tenantId              String
  empresaId             String
  produtoId             String             @unique
  regraTributariaId     String?
  produto               Produto            @relation(fields: [produtoId], references: [id])
  regraTributaria       RegraTributaria?   @relation(fields: [regraTributariaId], references: [id])
  ncm                   String
  cest                  String?
  origem                String?
  exTipi                String?
  codigoBeneficioFiscal String?
  finalidadePadrao      FinalidadeEntrada?
  // Mercadoria com ICMS já recolhido por substituição tributária (contribuinte substituído).
  // Memorizado na entrada (NF-e com CST 60/CSOSN 500): na revenda a saída sai sem ICMS próprio
  // (CST 60 / CSOSN 500) e com CFOP de ST (5405/6404), sem novo débito de ICMS.
  icmsSt                Boolean            @default(false)
  /// PIS/COFINS MONOFÁSICO (Leis 10.485 autopeças, 10.147 farmácia/perfumaria, 13.097 bebidas
  /// frias, 9.718 combustíveis): o fabricante/importador já recolheu — a REVENDA sai com alíquota
  /// zero e, no Simples, a receita é SEGREGADA no PGDAS-D (reduz o DAS). Sugerido por NCM,
  /// confirmado no cadastro.
  pisCofinsMonofasico   Boolean            @default(false)
  observacoes           String?
  criadoEm              DateTime           @default(now())
  atualizadoEm          DateTime           @updatedAt

  @@unique([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, ncm])
  @@index([tenantId, empresaId, cest])
  @@index([tenantId, empresaId, regraTributariaId])
}

model ProdutoFornecedor {
  id                  String     @id @default(cuid())
  tenantId            String
  empresaId           String
  produtoId           String
  fornecedorId        String
  produto             Produto    @relation(fields: [produtoId], references: [id])
  fornecedor          Fornecedor @relation(fields: [fornecedorId], references: [id])
  codigoFornecedor    String
  descricaoFornecedor String?
  gtinFornecedor      String?
  unidadeCompra       String     @default("UN")
  fatorConversao      Decimal    @default(1) @db.Decimal(14, 6)
  leadTimeDias        Int?
  compraMinima        Decimal?   @db.Decimal(14, 4)
  custoUltimaCompra   Decimal?   @db.Decimal(14, 4)
  principal           Boolean    @default(false)
  ativo               Boolean    @default(true)
  criadoEm            DateTime   @default(now())
  atualizadoEm        DateTime   @updatedAt

  @@unique([tenantId, empresaId, fornecedorId, codigoFornecedor])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, fornecedorId])
}

model Deposito {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  nome         String
  uf           String?
  ativo        Boolean            @default(true)
  lotes        EstoqueLote[]
  series       EstoqueSerie[]
  saldos       EstoqueSaldo[]
  movimentos   EstoqueMovimento[]
  reservas     EstoqueReserva[]
  pedidosVenda PedidoVenda[]
  inventarios  Inventario[]
  padrao       Boolean            @default(false)
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, nome])
  @@index([tenantId, empresaId])
}

model EstoqueSaldo {
  id           String       @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  loteId       String?
  controleKey  String       @default("SEM_CONTROLE")
  produto      Produto      @relation(fields: [produtoId], references: [id])
  deposito     Deposito     @relation(fields: [depositoId], references: [id])
  lote         EstoqueLote? @relation(fields: [loteId], references: [id])
  quantidade   Decimal      @default(0) @db.Decimal(14, 4)
  reservado    Decimal      @default(0) @db.Decimal(14, 4)
  minimo       Decimal      @default(0) @db.Decimal(14, 4)
  maximo       Decimal      @default(0) @db.Decimal(14, 4)
  atualizadoEm DateTime     @updatedAt

  @@unique([tenantId, empresaId, produtoId, depositoId, controleKey])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, depositoId])
}

model EstoqueMovimento {
  id             String               @id @default(cuid())
  tenantId       String
  empresaId      String
  produtoId      String
  depositoId     String
  loteId         String?
  serieId        String?
  produto        Produto              @relation(fields: [produtoId], references: [id])
  deposito       Deposito             @relation(fields: [depositoId], references: [id])
  lote           EstoqueLote?         @relation(fields: [loteId], references: [id])
  serie          EstoqueSerie?        @relation(fields: [serieId], references: [id])
  tipo           TipoMovimentoEstoque
  quantidade     Decimal              @db.Decimal(14, 4)
  saldoAntes     Decimal?             @db.Decimal(14, 4)
  saldoDepois    Decimal?             @db.Decimal(14, 4)
  custoUnitario  Decimal?             @db.Decimal(14, 4)
  custoTotal     Decimal?             @db.Decimal(14, 4)
  documentoTipo  String?
  documentoId    String?
  idempotencyKey String?
  usuarioId      String?
  origem         String?
  origemId       String?
  observacoes    String?
  criadoEm       DateTime             @default(now())

  @@unique([tenantId, empresaId, idempotencyKey])
  @@index([tenantId, empresaId, produtoId, depositoId, criadoEm])
  @@index([tenantId, empresaId, documentoTipo, documentoId])
}

model EstoqueLote {
  id           String             @id @default(cuid())
  tenantId     String
  empresaId    String
  produtoId    String
  depositoId   String
  produto      Produto            @relation(fields: [produtoId], references: [id])
  deposito     Deposito           @relation(fields: [depositoId], references: [id])
  numero       String
  fabricadoEm  DateTime?
  validadeEm   DateTime?
  saldos       EstoqueSaldo[]
  movimentos   EstoqueMovimento[]
  series       EstoqueSerie[]
  criadoEm     DateTime           @default(now())
  atualizadoEm DateTime           @updatedAt

  @@unique([tenantId, empresaId, produtoId, depositoId, numero])
  @@index([tenantId, empresaId, produtoId])
  @@index([tenantId, empresaId, validadeEm])
}

