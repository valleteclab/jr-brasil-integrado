# Variáveis de ambiente de PRODUÇÃO do ERP (VPS). Copie para `erp.env` na VPS, preencha os
# valores e proteja: chmod 600 erp.env. NÃO versione o erp.env real.
# Uso no deploy:  set -a; . ./erp.env; set +a; docker stack deploy -c deploy/erp-stack.yml erp

# Senha do Postgres dedicado do ERP (gere uma forte): openssl rand -base64 24
ERP_DB_PASSWORD=

# Segredo para criptografar chaves/segredos no banco (OBRIGATÓRIO, forte): openssl rand -hex 32
AI_CONFIG_SECRET=

# Credenciais do provedor fiscal ACBr (emissão NF-e/NFC-e/NFS-e em produção)
ACBR_CLIENT_ID=
ACBR_CLIENT_SECRET=

# E-mail do dono da plataforma (SaaS) e do admin inicial
PLATFORM_OWNER_EMAIL=
ADMIN_EMAIL=

# Integrações opcionais (deixe em branco se não usar)
DATALOAD_BASE_URL=
DATALOAD_DADOS_URL=
JRB_AGENT_API_KEY=
