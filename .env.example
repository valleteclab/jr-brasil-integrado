# ─── Banco de dados (obrigatório) ───────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jr_brasil_integrado?schema=public"

# URL pública da aplicação (usada em links/retornos). Em produção, o domínio real.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Criptografia de segredos (obrigatório) ─────────────────────────────────────
# Chave para criptografar (AES-256-GCM) credenciais de IA e tokens de provedores fiscais
# gravados no banco. SEM ela, salvar credenciais quebra. Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NUNCA troque essa chave depois de ter dados criptografados (perde acesso a eles).
AI_CONFIG_SECRET=""

# ─── Emissão fiscal — ACBr (obrigatório se emitir via ACBr) ──────────────────────
# Credenciais OAuth da APLICAÇÃO (plataforma/SaaS), não por empresa. Configure uma vez;
# todas as empresas emitem com elas. Cada empresa é registrada na ACBr (POST /empresas) + certificado.
ACBR_CLIENT_ID=""
ACBR_CLIENT_SECRET=""

# ─── Catálogo de produtos / imagens (opcional) ──────────────────────────────────
# APIs do Dataload para enriquecer produtos (imagem por GTIN e dados cadastrais).
# Sem elas, o enriquecimento automático fica indisponível (não quebra o cadastro manual).
DATALOAD_BASE_URL=""
DATALOAD_DADOS_URL=""

# ─── Seed / contas iniciais (obrigatório SÓ para rodar o seed) ──────────────────
# Senhas das contas criadas pelo seed — obrigatórias, sem fallback (mín. 8 caracteres).
# O seed NÃO roda com NODE_ENV=production a menos que SEED_ALLOW_PRODUCTION=1.
ADMIN_INITIAL_PASSWORD=""
# Dono da plataforma (painel /admin). Só é criado se o e-mail estiver definido.
PLATFORM_OWNER_EMAIL=""
PLATFORM_OWNER_PASSWORD=""
